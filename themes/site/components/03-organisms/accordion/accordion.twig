{#
/**
 * @file
 * Accordion component
 * 
 * Available variables:
 * - accordion_title - título principal del acordeón
 * - accordion_items - array de items del acordeón
 *   - title: título del item
 *   - content: contenido del item
 * - accordion_modifiers - array de modificadores BEM
 * - accordion_blockname - nombre del bloque BEM padre
 */
#}

{% set accordion_base_class = accordion_base_class|default('accordion') %}
{{ attach_library('tpms/accordion') }}

<section {{ bem(accordion_base_class, accordion_modifiers, accordion_blockname, ['container section-margin']) }}>


  {% if accordion_title %}
    <div class="accordion__header">
      {% include "@atoms/text/headings/_heading.twig" with {
          heading_level: 2,
          heading: accordion_title,
          heading_base_class: 'accordion__title',
          heading_icon: true,
          heading_underline: true
      } only %}
    </div>
  {% endif %} 

  <div class="accordion__list js-accordion">
    {% for item in accordion_items %}
      <div class="accordion__item{% if loop.first %} is-open{% endif %}" data-accordion-item>
        <div 
          class="accordion__header-wrapper"
          role="button"
          tabindex="0"
          aria-expanded="false"
          data-accordion-trigger
        >
          <div class="accordion__trigger-wrapper">
            <div class="accordion__trigger">
              <div class="accordion__trigger-inner">
                <div class="accordion__number-wrapper">
                  {% include "@atoms/text/headings/_heading.twig" with {
                    heading_level: 4,
                    heading: '%02d'|format(loop.index),
                    heading_base_class: 'accordion__number'
                  } only %}
                </div>

                {% include "@atoms/text/headings/_heading.twig" with {
                    heading_level: 4,
                    heading: item.title,
                    heading_base_class: 'accordion__item-title'
                } only %}
              </div>
            </div>
          </div>
          
          <span class="accordion__icon" aria-hidden="true"></span>
        </div>

        <div class="accordion__content" data-accordion-content>
          <div class="accordion__content-inner">
            {% include "@atoms/text/text/01-paragraph.twig" with {
              paragraph_content: item.content,
              paragraph_base_class: 'accordion__text'
            } %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>
