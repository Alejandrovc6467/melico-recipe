{#
/**
 * @file
 * Theme override to display a menu.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link URL, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 */
#}

{#
  We call a macro which calls itself to render the full tree.
  @see https://twig.symfony.com/doc/3.x/tags/macro.html
#}
{% import _self as menus %}

{{ menus.menu_links(items, attributes, 0) }}
{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% set ul_classes = [
      menu_level == 0 ? 'main-menu' : 'submenu',
    ] %}
    <ul{{ attributes.addClass(ul_classes) }}>
      {% for item in items %}
        {% set submenu_id = 'submenu-' ~ loop.index %} 
        {% set li_classes = ['menu-item'] %}
        {% if item.below %}
          {% set li_classes = li_classes|merge(['has-children']) %}
        {% endif %}
        {% if item.in_active_trail %}
          {% set li_classes = li_classes|merge(['is-active']) %}
        {% endif %}

        {% set item_attributes = item.attributes.addClass(li_classes) %}
        {% if item.below and menu_level == 0 %}
          {% set item_attributes = item_attributes.setAttribute('data-submenu', submenu_id) %}
        {% endif %}
        <li{{ item_attributes }}>

          {% if menu_level == 0 %}
            {% set link_attrs = {
              'link_url': item.url.toString(),
              'link_content': item.title,
              'link_modifiers': item.in_active_trail ? ['active'] : [],
              'link_blockname': 'menu',
              'has_icon': false
            } %}

            {% if item.url.isRouted %}
              {% set link_attrs = link_attrs|merge({
                'link_attributes': {
                  'data-drupal-link-system-path': item.url.internalPath
                }
              }) %}
            {% endif %}

            {% include "@atoms/item-menu/item-menu.twig" with link_attrs only %}
            {% if item.below %}
              {% include "@atoms/toggle-button/toggle-button.twig" with {
                icon_name: 'flecha-abajo-default',
                icon_width: '16',
                icon_height: '16',
                button_extra_classes: ['submenu-toggle'],
                button_data_attributes: {
                  'aria-expanded': 'false',
                  'aria-haspopup': 'true',
                  'aria-controls': submenu_id,
                  'aria-label': 'Abrir submenú de ' ~ item.title
                }
              } only %}
            {% endif %}
          {% else %}
            {% set link_attributes = {} %}
            {% if item.url.isRouted %}
              {% set link_attributes = link_attributes|merge({
                'data-drupal-link-system-path': item.url.internalPath
              }) %}
            {% endif %}
            {% set link_attr = create_attribute(link_attributes) %}
            <a href="{{ item.url.toString() }}"{{ link_attr }}>{{ item.title }}</a>
          {% endif %}
          {% if item.below and menu_level == 0 %}
            <div class="submenu-wrapper">
              {{ menus.menu_links(
                item.below,
                create_attribute().setAttribute('id', submenu_id),
                menu_level + 1
              ) }}
            </div>
          {% endif %}
        </li>

      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
