{#
/**
 * @file
 * Theme override for a breadcrumb trail.
 *
 * Available variables:
 * - breadcrumb: Breadcrumb trail items.
 */
#}
{% set breadcrumb__base_class = 'breadcrumb' %}

{% set breadcrumb_items = breadcrumb|default([]) %}
{% if breadcrumb_items|length > 1 %}
<div class="container">
  <nav role='navigation' aria-labelledby='system-breadcrumb'>
    <h2 {{ bem('visually-hidden') }} id='system-breadcrumb'>{{ 'Breadcrumb'|t }}</h2>
    <ol {{ bem(breadcrumb__base_class) }}>
    {% for item in breadcrumb_items %}
      <li {{ bem('item', [], breadcrumb__base_class, ['mini-text']) }}>
        {% if item.url %}
          <a {{ bem('link', [], breadcrumb__base_class, ['mini-text']) }} href="{{ item.url }}">{{ item.text }}</a>
        {% else %}
          {{ item.text }}
        {% endif %}
      </li>
    {% endfor %}
    </ol>
  </nav>
</div>
{% endif %}
