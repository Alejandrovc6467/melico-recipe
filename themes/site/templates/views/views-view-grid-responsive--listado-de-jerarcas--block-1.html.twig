{% set section_title = view.getTitle()|default('Nuestro Equipo') %}

<section class="team-section container section-margin">
  <div class="team-section__title">
    {% include "@atoms/text/headings/_heading.twig" with {
      heading_level: 2,
      heading: section_title,
      heading_blockname: 'team-section',
      heading_modifiers: ['title'],
      heading_icon: true,
      heading_underline: true
    } only %}
  </div>

  <div class="row team-section__row">
    {% for item in items %}
      <div class="col-12 col-md-6 col-lg-4 team-section__col">
        {{ item.content }}
      </div>
    {% endfor %}
  </div>
</section>
