{#
/**
 * Layout: Sección 1 columna centrada con container
 * Variables:
 * - settings.background_color: 'gris', 'azul' o 'blanco'
 * - content.content: contenido principal
 */
#}

{% set classes = [
  'layout',
  'layout--onecol-container',
] %}

{% if content %}
  <div{{ attributes.addClass(classes) }}>
    <div class="container">
      <div {{ region_attributes.content.addClass('layout__region', 'layout__region--content') }}>
        {{ content.content }}
      </div>
    </div>
  </div>
{% endif %}
