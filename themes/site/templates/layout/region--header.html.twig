{#
/**
 * @file
 * Theme override to display a region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region div.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 *
 * @see template_preprocess_region()
 */
#}

{% extends "@organisms/site/site-header/site-header.twig" %}

{% block header__branding %} 
  {% if elements.tpms_marcadelsitio and elements.tpms_marcadelsitio|render|striptags|trim %}
    {# Si el bloque de Drupal tiene contenido, usarlo #}
    {{ elements.tpms_marcadelsitio }}
  {% else %}
    {# Si no hay bloque configurado, usar el contenido por defecto del template padre #}
    {{ parent() }}
  {% endif %}
{% endblock %}

{% block header__menu %}
  {{ elements.tpms_navegacionprincipal }}
{% endblock %}


