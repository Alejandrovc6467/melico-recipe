{#
/**
 * @file
 * Default theme implementation to display a viewfield item.
 *
  * Instead of overriding the theming for all fields, you can also just override
 * theming for a subset of fields using
 * @link themeable Theme hook suggestions. @endlink For example,
 * here are some theme hook suggestions that can be used for a field_foo field
 * on an article node type:
 * - viewfield-item--my-view--my-view-display.html.twig
 * - viewfield-item--my-view-display.html.twig
 * - viewfield-item--my-view.html.twig
 * - viewfield-item--field-foo--my-view--my-view-display.html.twig
 * - viewfield-item--field-foo--my-view-display.html.twig
 * - viewfield-item--field-foo--my-view.html.twig
 * - viewfield-item--field-foo--2.html.twig
 * - viewfield-item--field-foo.html.twig
 * - viewfield-item.html.twig
 *
 * Available variables:
 * - title: The title of this item if visible.
 * - content: The content of this item.
 * - attributes: array of HTML attributes populated by modules, intended to
 *   be added to the main container tag of this template.
 * - title_attributes: Same as attributes, except applied to the main title
 *   tag that appears in the template.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 * - delta: Ordinal specifying the item number in the field.
 * - entity: The entity object.
 * - view_mode: View mode; e.g., 'full', 'teaser', etc.
 *
 * @see template_preprocess_viewfield_item()
 *
 * @ingroup themeable
 */
#}
{%
set classes = [
  'field__item',
  'field__item-label-' ~ label_display,
]
%}
{%
set title_classes = [
  'field__item__label',
  label_display == 'visually_hidden' ? 'visually-hidden',
]
%}

<div{{ attributes.addClass(classes) }}>
  {% if title %}
    <h1 class="vew-title">{{ title }}</h1>
  {% endif %}
  <div {{ attributes.addClass('page-section lista-noticias lista-noticias-general container section-margin') }}>

    <div class="layout">
      {# Sidebar desktop con botón de cerrar y título #}
      <div class="sidebar" id="sidebar">
        <div class="border_boton">
          <div class="cerrar">
            <div class="boton_cerrar">
              {% include "@atoms/images/icons/_icon.twig" with {
                icon__name: 'cerrar_filtro',
                icon__height: 24,
                icon__width: 24,
                directory: ''
              } %}
            </div>
            <div class="title">
              {% include "@atoms/text/headings/_heading.twig" with {
                heading_level: 3,
                heading: "Filters"
              } only %}
            </div>
          </div>
        </div>

        {# Filtros en sidebar desktop #}
        {{ drupal_block('views_exposed_filter_block:lista_de_noticias-block_4') }}
      </div>
    </div>
      
    <div class="sidebar-filtros">
      {# Botón móvil para abrir filtros #}
      {{ drupal_block('views_exposed_filter_block:lista_de_noticias-block_4') }}
      <div data-drupal-selector="edit-actions" class="form-actions js-form-wrapper form-wrapper actions-custom" id="edit-actions--4">
        <div class="sidebar-filtros__mobile_button">
          {% include "@atoms/buttons/button.twig" with {
            eventless: true,
            button_id: 'toggleSidebar',
            button_content: 'Filtros',
            button_modifiers: ['tertiary-border'],
            button_icon: {
              icon_name: 'filtro',
              icon_height: 24,
              icon_width: 24,
              directory: ''
            }
          } %}
        </div>
        <input data-drupal-selector="edit-submit-lista-de-noticias-4" type="submit" id="edit-submit-lista-de-noticias--4" value="Buscar" class="button button-primary js-form-submit form-submit form-item__textfield  buscar">
      </div>
    </div>

    {% block cards %}
      {% include "@organisms/lista-noticias/lista-noticias.twig" with {
        cards: cards,
        pager: pager
      } %}
    {% endblock %}

  </div>
</div>