        'as' => 'style',
      ],
    ],
    'tpms_preload_css',
  ];

}

/**
 * Prepara y estructura las variables necesarias para renderizar el componente de efemérides.
 *
 * Esta función obtiene los nodos de efemérides desde la vista correspondiente, extrae y organiza
 * los datos relevantes (título, descripción, día, mes y URL) para cada efeméride, y configura
 * la paginación y el enlace "ver más" si están habilitados en la vista. Los datos procesados
 * se asignan a las variables que serán utilizadas en la plantilla Twig del componente.
 */

function tpms_truncate_html($html, $limit = 500, $ending = '...')
{
  $plain = trim(strip_tags($html));
  if (mb_strlen($plain) <= $limit) {
    return $html;
  }
  $count = 0;
  $truncated = '';
  $dom = new DOMDocument();
  libxml_use_internal_errors(true);
  $dom->loadHTML('<?xml encoding="utf-8" ?>' . $html, LIBXML_HTML_NOIMPLIED | LIBXML_HTML_NODEFDTD);
  $body = $dom->getElementsByTagName('body')->item(0);
  $processed = false;
  if ($body && $body->childNodes && $body->childNodes->length > 0) {
    foreach ($body->childNodes as $node) {
      $fragment = '';
      tpms_truncate_html_node($node, $limit, $count, $fragment, $ending);
      $truncated .= $fragment;
      if ($count >= $limit) {
        break;
      }
    }
    $processed = true;
  }
  // Fallback: intentar procesar el primer hijo del documento
  if (!$processed && $dom->childNodes && $dom->childNodes->length > 0) {
    foreach ($dom->childNodes as $node) {
      $fragment = '';
      tpms_truncate_html_node($node, $limit, $count, $fragment, $ending);
      $truncated .= $fragment;
      if ($count >= $limit) {
        break;
      }
    }
    $processed = true;
  }
  // Fallback final: texto plano truncado
  if (!$processed) {
    $truncated = mb_substr($plain, 0, $limit) . $ending;
  }
  return $truncated;
}
/**
 * Trunca un fragmento de HTML a un número máximo de caracteres, preservando etiquetas.
 *
 * Esta función toma un string HTML y lo recorta a un límite de caracteres especificado,
 * intentando mantener la estructura HTML válida y agregando un sufijo (por defecto '...')
 * si el texto es truncado. Si el HTML es muy simple o no puede ser procesado como DOM,
 * realiza un truncado plano del texto.
 *
 * @param string $html
 *   El contenido HTML a truncar.
 * @param int $limit
 *   El número máximo de caracteres permitidos (por defecto 500).
 * @param string $ending
 *   El texto a añadir al final si se trunca (por defecto '...').
 *
 * @return string
 *   El HTML truncado, preservando etiquetas en lo posible.
 */

function tpms_truncate_html_node($node, $limit, &$count, &$output, $ending)
{
  if ($count >= $limit) {
    return;
  }
  if ($node->nodeType === XML_TEXT_NODE) {
    $text = $node->nodeValue;
    $remaining = $limit - $count;
    if (mb_strlen($text) > $remaining) {
      $output .= mb_substr($text, 0, $remaining) . $ending;
      $count += $remaining;
    } else {
      $output .= $text;
      $count += mb_strlen($text);
    }
  } elseif ($node->nodeType === XML_ELEMENT_NODE) {
    $output .= '<' . $node->nodeName;
    if ($node->hasAttributes()) {
      foreach ($node->attributes as $attr) {
        $output .= ' ' . $attr->nodeName . '="' . htmlspecialchars($attr->nodeValue) . '"';
      }
    }
    $output .= '>';
    foreach ($node->childNodes as $child) {
      mcj_truncate_html_node($child, $limit, $count, $output, $ending);
      if ($count >= $limit) {
        break;
      }
    }
    $output .= '</' . $node->nodeName . '>';
  }
}

/**
 * Implements hook_preprocess_viewfield for tipos_de_instituciones block_1.
 */
function tpms_preprocess_viewfield_item__tipos_de_instituciones__block_1(array &$variables)
{
  // Cargar y ejecutar la vista que lista términos de taxonomía.
  if ($view = Views::getView('tipos_de_instituciones')) {
    $view->setDisplay('block_1');
    $view->execute();

    $items = [];

    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $row) {
      /** @var Term $term */
      $term = $row->_entity;
      $title = $term->getName();

      // Inicializar imagen vacía
      $image = ['url' => '', 'alt' => ''];

      // Obtener imagen desde field_imagen_org_type
      if ($term->hasField('field_imagen_org_type') && !$term->get('field_imagen_org_type')->isEmpty()) {
        $media = $term->get('field_imagen_org_type')->entity;
        if ($media instanceof MediaInterface && $media->hasField('field_media_image') && !$media->get('field_media_image')->isEmpty()) {
          $file = $media->get('field_media_image')->entity;
          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();
            if ($style = ImageStyle::load('full')) {
              $image['url'] = $style->buildUrl($uri);
            }
            $image['alt'] = $media->get('field_media_image')->alt ?? '';
          }
        }
      }

      $items[] = [
        'category'       => $title,
        'image'          => $image,
        'term_id'  => $term->id(),
      ];
    }

    $variables['items'] = $items;

    if (
      !empty($variables['element']['#paragraph']) &&
      $variables['element']['#paragraph'] instanceof ParagraphInterface &&
      !empty($variables['element']['#content']['#view']) &&
      $variables['element']['#content']['#view'] instanceof ViewExecutable
    ) {
      $paragraph = $variables['element']['#paragraph'];

      $titulo = $paragraph->get('field_titulo')->value;
      $descripcion = $paragraph->get('field_descripcion_tipos_ins')->value;

      // 2. Procesar field_link
      $link_item = $paragraph->get('field_link')->first();
      $link_uri = '';
      $link_title = '';

      if ($link_item) {
        $uri = $link_item->uri;
        $link_uri = Url::fromUri($uri)->toString();
        $link_title = $link_item->title ?: $link_uri;
      }

      // 3. Estructura para Twig
      $variables['cta'] = [
        'title' => $titulo,
        'body'  => $descripcion,
        'url'   => [
          'uri'  => $link_uri,
          'text' => $link_title,
        ],
      ];
    }
  }
}

function tpms_preprocess_paragraph__nuestras_instituciones_carrusel(&$variables)
{
  if (
    isset($variables['paragraph']) &&
    $variables['paragraph'] instanceof ParagraphInterface &&
    isset($variables['content']['field_reference']) &&
    is_array($variables['content']['field_reference'])
  ) {
    // field_reference puede tener varios items (delta 0,1,2…).
    foreach ($variables['content']['field_reference'] as &$item) {
      if (is_array($item)) {
        // “Transportamos” la entidad párrafo para que el hook de Viewfield
        // pueda leerla más tarde:
        $item['#paragraph'] = $variables['paragraph'];
      }
    }
  }
}

function tpms_preprocess_paragraph__view_reference(&$variables)
{
  if (
    isset($variables['paragraph']) &&
    $variables['paragraph'] instanceof ParagraphInterface &&
    isset($variables['content']['field_reference']) &&
    is_array($variables['content']['field_reference'])
  ) {
    foreach ($variables['content']['field_reference'] as &$item) {
      if (is_array($item)) {
        $item['#paragraph'] = $variables['paragraph'];
      }
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for group templates.
 */
function tpms_preprocess_group(array &$variables)
{
  $group = $variables['group'];

  // Solo para el bundle "institucion" en view mode "full".
  $view_mode = $variables['elements']['#view_mode'] ?? ($variables['view_mode'] ?? '');
  if ($group->bundle() !== 'institucion' || $view_mode !== 'full') {
    return;
  }

  $grupo = [
    'title'         => $group->label(),
    'image'         => ['url' => '', 'alt' => ''],
    'provincia'     => '',
    'external_link' => NULL,
    'body'          => '',
    'categorias'    => [],
  ];

  // 1. Imagen principal (field_imagen) via Media → File → ImageStyle.
  if ($group->hasField('field_imagen') && !$group->get('field_imagen')->isEmpty()) {
    $media = $group->get('field_imagen')->entity;
    if (
      $media instanceof MediaInterface
      && $media->hasField('field_media_image')
      && !$media->get('field_media_image')->isEmpty()
    ) {

      $file = $media->get('field_media_image')->entity;
      if ($file instanceof FileInterface) {
        $uri = $file->getFileUri();

        // Aplica el estilo de imagen 'full' (ajusta si es otro).
        if ($style = ImageStyle::load('full')) {
          $grupo['image']['url'] = $style->buildUrl($uri);
        }

        // Alt del subcampo.
        $grupo['image']['alt'] = $media->get('field_media_image')->alt ?? '';
      }
    }
  }

  // 2. Provincia (field_provincia).
  if ($group->hasField('field_provincia') && !$group->get('field_provincia')->isEmpty()) {
    $prov = $group->get('field_provincia')->first()->entity;
    $grupo['provincia'] = $prov ? $prov->label() : '';
  }

  // 3. Enlace externo (field_enlace_externo).
  if ($group->hasField('field_enlace_externo') && !$group->get('field_enlace_externo')->isEmpty()) {
    $link_item = $group->get('field_enlace_externo')->first();
    $url       = $link_item->getUrl();
    $value     = $link_item->getValue();
    $grupo['external_link'] = [
      'uri'    => $url->toString(),
      'title'  => $value['title']   ?? $url->toString(),
      'target' => $value['options']['attributes']['target'] ?? '_self',
    ];
  }

  // 4. Cuerpo de texto (field_body).
  if ($group->hasField('field_body') && !$group->get('field_body')->isEmpty()) {
    $body = $group->get('field_body')->first()->getValue();
    $grupo['body'] = [
      'value'  => $body['value'],
      'format' => $body['format'],
    ];
  }

  // 5. Categorías (field_categorias_del_event): nombre + icono raw.
  if ($group->hasField('field_tipo_de_institucion') && !$group->get('field_tipo_de_institucion')->isEmpty()) {
    $terms = $group->get('field_tipo_de_institucion')->referencedEntities();
    foreach ($terms as $term) {
      $grupo['categorias'][] = [
        'name' => $term->getName(),
      ];
    }
  }

  // Inyecta todo en Twig.
  $variables['grupo'] = $grupo;
}

/**
 * @file
 * Theme override for breadcrumbs, añadiendo un “< Volver” al final.
 */
function tpms_preprocess_breadcrumb(array &$variables)
{
  // Si no hay breadcrumb o solo un ítem, no hacemos nada.
  if (empty($variables['breadcrumb']) || count($variables['breadcrumb']) < 2) {
    $variables['breadcrumb'] = [];
    return;
  }

  $items = $variables['breadcrumb'];

  $target_url = NULL;
  for ($i = count($items) - 1; $i >= 0; --$i) {
    if (!empty($items[$i]['url'])) {
      $target_url = $items[$i]['url'];
      break;
    }
  }

  if ($target_url === NULL) {
    $target_url = Url::fromRoute('<front>');
  }

  $newItem = [
    'text' => t('< Volver'),
    'url'  => $target_url,
  ];

  $variables['breadcrumb'][] = $newItem;
}

function tpms_preprocess_paragraph__banner_principal(&$variables)
{
  $paragraph = $variables['paragraph'];

  $slides = [];
  /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */
  $paragraph = $variables['paragraph'];
  $test = $paragraph->field_item_banner[0]->entity;


  $slides = [];

  if ($paragraph->hasField('field_item_banner') && !$paragraph->get('field_item_banner')->isEmpty()) {
    foreach ($paragraph->get('field_item_banner')->referencedEntities() as $slide_p) {

      // ===== Texto =====
      $title = (!$slide_p->get('field_titulo')->isEmpty())
        ? $slide_p->get('field_titulo')->value
        : '';

      $venue = (!$slide_p->get('field_subheading')->isEmpty())
        ? $slide_p->get('field_subheading')->value
        : '';

      // En tu debug se ve que esto ya viene como string "MM/DD/YYYY ... - ...".
      $date_items = [];
      if (!$slide_p->get('field_rango_de_fecha')->isEmpty()) {
        foreach ($slide_p->get('field_rango_de_fecha') as $item) {
          $date_items[] = $item->daterangepicker;
        }
      }

      // Formateo bonito
      $items = [];
      $locale = 'en_US';

      foreach ($date_items as $range) {
        $parts = array_map('trim', explode(' - ', $range));
        if (count($parts) !== 2) continue;

        $start = \DateTime::createFromFormat('m/d/Y h:i A', $parts[0]);
        $end   = \DateTime::createFromFormat('m/d/Y h:i A', $parts[1]);
        if (!$start || !$end) continue;

        $fmtStartM = new \IntlDateFormatter($locale, \IntlDateFormatter::NONE, \IntlDateFormatter::NONE, $start->getTimezone()->getName(), \IntlDateFormatter::GREGORIAN, 'MMM');
        $fmtEndM   = new \IntlDateFormatter($locale, \IntlDateFormatter::NONE, \IntlDateFormatter::NONE, $end->getTimezone()->getName(),   \IntlDateFormatter::GREGORIAN, 'MMM');

        $startY = (int) $start->format('Y');
        $endY   = (int) $end->format('Y');
        $startD = (int) $start->format('j');
        $endD   = (int) $end->format('j');

        $startM = $fmtStartM->format($start);
        $endM   = $fmtEndM->format($end);

        $sameDay  = $start->format('Y-m-d') === $end->format('Y-m-d');
        $sameYM   = $start->format('Y-m') === $end->format('Y-m');
        $sameYear = $startY === $endY;

        if ($sameDay) {
          $text = "{$startD} {$startM}";
          $items[] = ['text' => $text, 'year' => $startY, 'cross_year' => false, 'ts' => $start->getTimestamp()];
        } else {
          if ($sameYM) {
            $text = "{$startD}-{$endD} {$startM}";
            $items[] = ['text' => $text, 'year' => $startY, 'cross_year' => false, 'ts' => $start->getTimestamp()];
          } elseif ($sameYear) {
            $text = "{$startD} {$startM} - {$endD} {$endM}";
            $items[] = ['text' => $text, 'year' => $startY, 'cross_year' => false, 'ts' => $start->getTimestamp()];
          } else {
            $text = "{$startD} {$startM}, {$startY} - {$endD} {$endM}, {$endY}";
            $items[] = ['text' => $text, 'year' => null, 'cross_year' => true, 'ts' => $start->getTimestamp()];
          }
        }
      }

      usort($items, fn($a, $b) => $a['ts'] <=> $b['ts']);
      $texts = array_values(array_unique(array_map(fn($i) => $i['text'], $items)));
      $years = array_values(array_unique(array_filter(array_map(fn($i) => $i['year'], $items))));
      $hasCrossYear = (bool) array_filter($items, fn($i) => !empty($i['cross_year']));

      $date_text = '';
      if (!empty($texts)) {
        $date_text = (!$hasCrossYear && count($years) === 1)
          ? implode(', ', $texts) . ', ' . $years[0]
          : implode(', ', $texts);
      }


      // ===== Imagen (field_imagen) =====
      $image_url = '';
      $image_alt = '';
      $image_style_name = null;

      $view_mode = $variables['view_mode'] ?? 'default';
      $bundle = $slide_p->bundle();

      $display_id = "paragraph.{$bundle}.{$view_mode}";
      $display = \Drupal::entityTypeManager()
        ->getStorage('entity_view_display')
        ->load($display_id);

      $component = $display->getComponent('field_imagen');
      $image_style_name = $component['settings']['image_style'];

      $image_entity = $slide_p->get('field_imagen')->entity;

      if ($image_entity instanceof Media) {
        $img_item = $image_entity->get('field_media_image')->first();

        if ($img_item && $img_item->entity) {
          $uri = $img_item->entity->getFileUri();
          $image_alt = $img_item->alt ?? '';

          $style = ImageStyle::load($image_style_name);
          $image_url = $style->buildUrl($uri);
        }
      }

      // ===== Botones (field_boton) =====
      // Se esperan hasta 2 referencias: 0 = Ver más, 1 = Comprar entradas
      $more_url = '';
      $more_label = '';
      $tickets_url = '';
      $tickets_label = '';

      if ($slide_p->hasField('field_boton') && !$slide_p->get('field_boton')->isEmpty()) {
        $buttons = $slide_p->get('field_boton')->referencedEntities();

        // ===== Botón 0 => Ver más =====
        if (!empty($buttons[0])) {
          $btn = $buttons[0];

          if ($btn->hasField('field_link') && !$btn->get('field_link')->isEmpty()) {
            $link = $btn->get('field_link')->first()->getUrl()->toString();

            // Label
            $more_label = $btn->get('field_link')->first()->title ?? '';

            // URL
            $more_url = $link;
          }
        }

        // ===== Botón 1 => Comprar entradas =====
        if (!empty($buttons[1])) {
          $btn = $buttons[1];

          if ($btn->hasField('field_link') && !$btn->get('field_link')->isEmpty()) {
            $link = $btn->get('field_link')->first()->getUrl()->toString();
            // Label
            $tickets_label = $btn->get('field_link')->first()->title ?? '';

            // URL
            $tickets_url = $link;
          }
        }
      }


      $slides[] = [
        'image' => $image_url,
        'image_alt' => $image_alt,
        'title' => $title,
        'venue' => $venue,
        'date_range' => $date_text,
        'more_url' => $more_url,
        'more_label' => $more_label ?: 'Ver más',
        'tickets_url' => $tickets_url,
        'tickets_label' => $tickets_label ?: 'Comprar entradas',
      ];
    }
  }

  // Variables para el componente
  $variables['slides'] = $slides;
}

/**
 * Preprocess: View "programas-artisticos" display "block_1".
 *
 * Archivo twig: views-view--programas-artisticos--block-1.html.twig
 * Hook: tpms_preprocess_views_view__programas_artisticos__block_1()
 */
function tpms_preprocess_viewfield_item__programas_artisticos__block_1(array &$variables): void
{
  $paragraph = NULL;
  if (!empty($variables['element']['#paragraph']) && $variables['element']['#paragraph'] instanceof ParagraphInterface) {
    $paragraph = $variables['element']['#paragraph'];
  } elseif (!empty($variables['entity']) && $variables['entity'] instanceof ParagraphInterface) {
    $paragraph = $variables['entity'];
  }

  if ($paragraph && $paragraph->hasField('field_heading') && !$paragraph->get('field_heading')->isEmpty()) {
    $variables['programas_title'] = $paragraph->get('field_heading')->value;
  }
}

/**
 * Implements hook_theme_suggestions_HOOK_alter() for views_view_grid_responsive.
 */
function tpms_theme_suggestions_views_view_grid_responsive_alter(array &$suggestions, array $variables)
{
  $view = $variables['view'];
  $suggestions[] = 'views_view_grid_responsive__' . $view->id();
  $suggestions[] = 'views_view_grid_responsive__' . $view->id() . '__' . $view->current_display;
}


function tpms_preprocess_views_view__lista_espacios__block_1(array &$variables)
{
  if (empty($variables['rows'])) {
    $variables['espacios_groups'] = [];
    return;
  }

  $renderer = \Drupal::service('renderer');
  $groups = [];

  foreach ($variables['rows'] as $group) {

    if (empty($group['#rows'])) {
      continue;
    }

    $institution_name = '';

    if (!empty($group['#title'])) {
      if (is_array($group['#title'])) {
        $institution_name = trim(strip_tags(
          $renderer->renderPlain($group['#title'])
        ));
      } else {
        $institution_name = trim(strip_tags((string) $group['#title']));
      }
    }

    $groups[] = [
      'institution_name' => $institution_name,
      'rows' => $group['#rows'],
    ];
  }

  $variables['espacios_groups'] = $groups;
}

function tpms_preprocess_views_view__lista_espacios__block_2(array &$variables)
{
  $route_match = \Drupal::routeMatch();
  $node = $route_match->getParameter('node');

  if (is_numeric($node)) {
    $node = Node::load((int) $node);
  }

  if ($node instanceof NodeInterface) {
    $variables['host_node_title'] = $node->label();
    $variables['host_node_id'] = $node->id();
  }
}



/**
 * Implements template_preprocess_paragraph() for informacion_con_iconos.
 */
function tpms_preprocess_paragraph__informacion_con_iconos(&$variables)
{
  /** @var \Drupal\paragraphs\ParagraphInterface $paragraph */
  $paragraph = $variables['paragraph'];

  // Validar que el paragraph tenga el campo de tipo de componente
  if (!$paragraph->hasField('field_tipo_de_componente') || $paragraph->get('field_tipo_de_componente')->isEmpty()) {
    return;
  }

  $component_type = $paragraph->get('field_tipo_de_componente')->value;

  // Obtener título y descripción (comunes para variantes)
  $variables['title'] = $paragraph->hasField('field_titulo') && !$paragraph->get('field_titulo')->isEmpty()
    ? $paragraph->get('field_titulo')->value
    : '';

  $variables['description'] = $paragraph->hasField('field_description') && !$paragraph->get('field_description')->isEmpty()
    ? $paragraph->get('field_description')->value
    : '';

  // Procesar items según el tipo de componente seleccionado
  switch ($component_type) {

    case 'butacas':
      $items = [];
      if ($paragraph->hasField('field_items_butacas') && !$paragraph->get('field_items_butacas')->isEmpty()) {
        foreach ($paragraph->get('field_items_butacas') as $item) {
          $entity = $item->entity;
          if (!$entity) continue;

          $items[] = [
            'capacity' => $entity->hasField('field_capacidad') && !$entity->get('field_capacidad')->isEmpty()
              ? $entity->get('field_capacidad')->value : '',
            'label' => $entity->hasField('field_etiqueta') && !$entity->get('field_etiqueta')->isEmpty()
              ? $entity->get('field_etiqueta')->value : '',
          ];
        }
      }
      $variables['butacas_items'] = $items;
      break;

    case 'variante_dorada':
      $items = [];
      if ($paragraph->hasField('field_items_variante_dorada') && !$paragraph->get('field_items_variante_dorada')->isEmpty()) {
        foreach ($paragraph->get('field_items_variante_dorada') as $item) {
          $entity = $item->entity;
          if (!$entity) continue;

          $icon_render = [];
          if ($entity->hasField('field_icono') && !$entity->get('field_icono')->isEmpty()) {
            $icon_render = $entity->get('field_icono')->view([
              'label' => 'hidden',
              'type' => 'iconify_icon',
            ]);
          }

          $items[] = [
            'icon' => $icon_render,
            'title' => $entity->hasField('field_titulo') && !$entity->get('field_titulo')->isEmpty()
              ? $entity->get('field_titulo')->value : '',
            'description' => $entity->hasField('field_historico_descripcion') && !$entity->get('field_historico_descripcion')->isEmpty()
              ? $entity->get('field_historico_descripcion')->value : '',
          ];
        }
      }
      $variables['variante_dorada_items'] = $items;
      break;

    case 'variante_azul':
      $items = [];
      if ($paragraph->hasField('field_items_variante_azul') && !$paragraph->get('field_items_variante_azul')->isEmpty()) {
        foreach ($paragraph->get('field_items_variante_azul') as $item) {
          $entity = $item->entity;
          if (!$entity) continue;

          $icon_render = [];
          if ($entity->hasField('field_icono') && !$entity->get('field_icono')->isEmpty()) {
            $icon_render = $entity->get('field_icono')->view([
              'label' => 'hidden',
              'type' => 'iconify_icon',
            ]);
          }

          $items[] = [
            'icon' => $icon_render,
            'title' => $entity->hasField('field_titulo') && !$entity->get('field_titulo')->isEmpty()
              ? $entity->get('field_titulo')->value : '',
            'description' => $entity->hasField('field_historico_descripcion') && !$entity->get('field_historico_descripcion')->isEmpty()
              ? $entity->get('field_historico_descripcion')->value : '',
          ];
        }
      }
      $variables['variante_azul_items'] = $items;
      break;
  }
}

/**
 * Prepara las variables del paragraph Galería (título, imágenes y botón) 
 * para ser pasadas al componente de Storybook.
 */
function tpms_preprocess_paragraph__galeria(&$variables)
{
  $paragraph = $variables['paragraph'];

  $variables['gallery_title'] = $paragraph->field_titulo->value ?? '';

  $variables['gallery_images'] = [];
  if ($paragraph->hasField('field_image') && !$paragraph->field_image->isEmpty()) {
    $file_url_generator = \Drupal::service('file_url_generator');
    foreach ($paragraph->field_image as $delta => $media_item) {
      if ($media_item->entity) {
        $media = $media_item->entity;
        if ($media->hasField('field_media_image') && !$media->field_media_image->isEmpty()) {
          $image_field = $media->field_media_image->first();

          $image_uri = $variables['content']['field_image'][$delta]['#uri'];
          $image_style = $variables['content']['field_image'][$delta]['#image_style'];

          $image_original_url = $file_url_generator->transformRelative(
            $file_url_generator->generateAbsoluteString($image_uri),
          );

          $image_url = $image_original_url;
          if (!empty($image_style)) {
            $style = \Drupal\image\Entity\ImageStyle::load($image_style);
            if ($style) {
              $image_url = $style->buildUrl($image_uri);
              $image_url = $file_url_generator->transformRelative($image_url);
            }
          }

          $variables['gallery_images'][] = [
            'image_src' => $image_url,
            'image_original_src' => $image_original_url,
            'image_alt' => $image_field->alt ?? '',
          ];
        }
      }
    }
  }

  if ($paragraph->hasField('field_boton') && !$paragraph->field_boton->isEmpty()) {
    $boton_paragraph = $paragraph->field_boton->entity;
    if ($boton_paragraph && $boton_paragraph->hasField('field_link') && !$boton_paragraph->field_link->isEmpty()) {
      $link = $boton_paragraph->field_link->first();
      $variables['gallery_button_text'] = $link->title ?? '';
      $variables['gallery_button_url'] = $link->getUrl()->toString() ?? '';
    }
  }
}



function tpms_preprocess_views_view__espacios_relacionados2__block_1(array &$variables)
{
  $view = $variables['view'];

  $count = isset($view->total_rows) ? (int) $view->total_rows : count($view->result);

  $variables['espacios_count'] = $count;
  $variables['title'] = $count . ' Espacios:';
  unset($variables['espacios_items']);
}

function tpms_preprocess_node__espacios__espacios_relacionados(array &$variables)
{
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];
  if (!$node instanceof NodeInterface) {
    return;
  }

  $label = $node->label();
  $image_url = '';
  $image_alt = $label;

  if ($node->hasField('field_imagen') && !$node->get('field_imagen')->isEmpty()) {
    $media = $node->get('field_imagen')->entity;

    if ($media) {
      $media_image_field = 'field_media_image';

      if ($media->hasField($media_image_field) && !$media->get($media_image_field)->isEmpty()) {
        $image_item = $media->get($media_image_field)->first();
        $file = $image_item ? $image_item->entity : NULL;

        if ($file) {
          $image_url = \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
        }

        if ($image_item && !empty($image_item->alt)) {
          $image_alt = $image_item->alt;
        }
      }
    }
  }

  $variables['galeria_item'] = [
    'image' => $image_url,
    'alt' => $image_alt,
    'label' => $label,
  ];
}


function tpms_preprocess_viewfield_item__lista_centros_civicos_slider__block_1(array &$variables)
{
  $view = '';
  if ($view = Views::getView($variables['content']['#name'])) {
    $view->setDisplay($variables['content']['#display_id']);
    $view->execute();
  }

  $items = [];

  foreach ($view->result as $row) {
    $node = $row->_entity ?? NULL;
    if (!$node instanceof NodeInterface) {
      continue;
    }

    $name = $node->label();

    $media_image_field = $node->get('field_imagen')->entity;

    if ($media_image_field && $media_image_field->hasField('field_media_image') && !$media_image_field->get('field_media_image')->isEmpty()) {
      $image_url = $media_image_field->get('field_media_image')->view([
        'label' => 'hidden',
        'type' => 'image',
        'settings' => [
          'image_style' => '285x320_centros_civicos',
        ],
      ]);
    }

    $role = $node->hasField('field_subtitulo') && !$node->get('field_subtitulo')->isEmpty()
      ? trim($node->get('field_subtitulo')->value)
      : '';


    $email = $node->hasField('field_correo') && !$node->get('field_correo')->isEmpty()
      ? trim($node->get('field_correo')->value)
      : '';

    $phone = $node->hasField('field_telefono') && !$node->get('field_telefono')->isEmpty()
      ? trim($node->get('field_telefono')->value)
      : '';


    $sede_label = 'SEDE';
    $sede_text = '';

    if ($node->hasField('field_ubicacion_sede') && !$node->get('field_ubicacion_sede')->isEmpty()) {
      $term = $node->get('field_ubicacion_sede')->entity;

      if ($term instanceof TermInterface) {
        $sede_text = $term->label();
      }
    }

    $body = [];

    if ($node->hasField('field_descripcion') && !$node->get('field_descripcion')->isEmpty()) {
      $text = trim($node->get('field_descripcion')->value);

      if ($text) {
        $body = array_values(
          array_filter(
            array_map('trim', preg_split("/\R\R+/", $text))
          )
        );
      }
    }


    $items[] = [
      'sede_label' => $sede_label,
      'sede_text'  => $sede_text,
      'role'       => $role,
      'name'       => $name,
      'email'      => $email,
      'phone'      => $phone,
      'image_url' => $image_url,
      'body'       => $body,
    ];
  }

  $paragraph = NULL;
  if (!empty($variables['element']['#paragraph']) && $variables['element']['#paragraph'] instanceof ParagraphInterface) {
    $paragraph = $variables['element']['#paragraph'];
  } elseif (!empty($variables['entity']) && $variables['entity'] instanceof ParagraphInterface) {
    $paragraph = $variables['entity'];
  }

  if ($paragraph && $paragraph->hasField('field_heading') && !$paragraph->get('field_heading')->isEmpty()) {
    $variables['title_heading'] = $paragraph->get('field_heading')->value;
  }
  if ($paragraph && $paragraph->hasField('field_description') && !$paragraph->get('field_description')->isEmpty()) {
    $variables['description_heading'] = $paragraph->get('field_description')->value;
  }
  $variables['ccp_intro'] = '';
  $variables['ccp_items'] = $items;
  $variables['content']['#access'] = FALSE;
}
/**
 * Implements hook_preprocess_HOOK() for paragraph--archivos-adjuntos.
 */
function tpms_preprocess_paragraph__archivos_adjuntos(&$variables)
{
  /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */
  $paragraph = $variables['paragraph'];

  // Obtener tipo de visualización
  $variables['tipo_visualizacion'] = $paragraph->field_tipo_de_visualizacion->value ?? 'con_imagen';

  // Extraer valores comunes
  $variables['archivos_title'] = $paragraph->field_titulo->value ?? '';
  $variables['archivos_description'] = $paragraph->field_descripcion->value ?? '';

  // Construir array de archivos adjuntos
  $variables['archivos_items'] = [];
  if (!$paragraph->field_archivos_adjuntos->isEmpty()) {
    foreach ($paragraph->field_archivos_adjuntos as $item) {
      if ($item->entity) {
        /** @var \Drupal\file\Entity\File $file */
        $file = $item->entity;
        $variables['archivos_items'][] = [
          'label' => $item->description ?: $file->getFilename(),
          'url' => $file->createFileUrl(),
        ];
      }
    }
  }

  // Variables específicas según el tipo de visualización
  if ($variables['tipo_visualizacion'] === 'con_imagen') {
    // Procesar imagen con image style
    $variables['archivos_image'] = NULL;
    $variables['archivos_image_alt'] = '';

    if (!$paragraph->field_imagen->isEmpty()) {
      $image_uri = $variables['content']['field_imagen'][0]['#uri'] ?? NULL;
      $image_style_name = $variables['content']['field_imagen'][0]['#image_style'] ?? NULL;

      if ($image_uri && $image_style_name) {
        // Aplicar image style
        $image_style = ImageStyle::load($image_style_name);
        if ($image_style) {
          $variables['archivos_image'] = $image_style->buildUrl($image_uri);
        }
      } elseif ($image_uri) {
        // Fallback: usar imagen sin style
        $variables['archivos_image'] = \Drupal::service('file_url_generator')->generateAbsoluteString($image_uri);
      }

      // Obtener alt text
      $variables['archivos_image_alt'] = $variables['content']['field_imagen'][0]['#item']->alt ?? '';
    }
  } else {
    // Variable específica para componente simple
    $variables['section_margin'] = $paragraph->field_activar_margen_de_seccion->value ?? TRUE;
  }
}



function tpms_preprocess_paragraph__linea_de_tiempo_historia(&$variables)
{
  /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */
  $paragraph = $variables['paragraph'];

  $slider_items = [];

  // Obtener los items de historia referenciados
  if ($paragraph->hasField('field_items_historias') && !$paragraph->get('field_items_historias')->isEmpty()) {

    foreach ($paragraph->get('field_items_historias')->referencedEntities() as $item_paragraph) {

      $image_url = NULL;
      $image_style_name = NULL;
      $image_alt = '';

      // Obtener la imagen desde el campo de Media
      if ($item_paragraph->hasField('field_imagen') && !$item_paragraph->get('field_imagen')->isEmpty()) {

        // Obtener el display del paragraph para ver la configuración del image style
        $display = \Drupal::service('entity_display.repository')
          ->getViewDisplay('paragraph', $item_paragraph->bundle(), 'default');

        if ($display) {
          $field_config = $display->getComponent('field_imagen');
          if ($field_config && isset($field_config['settings']['image_style'])) {
            $image_style_name = $field_config['settings']['image_style'];
          }
        }

        // Fallback si no se encuentra en el display
        if (!$image_style_name) {
          $image_style_name = 'large';
        }

        /** @var \Drupal\media\MediaInterface $media */
        $media = $item_paragraph->get('field_imagen')->entity;

        if ($media instanceof MediaInterface) {

          // Auto-detectar el campo de imagen en la media
          $image_field_name = NULL;
          foreach ($media->getFieldDefinitions() as $field_name => $field_definition) {
            if ($field_definition->getType() === 'image' && $media->hasField($field_name) && !$media->get($field_name)->isEmpty()) {
              $image_field_name = $field_name;
              break;
            }
          }

          if ($image_field_name) {
            /** @var \Drupal\file\FileInterface $file */
            $file = $media->get($image_field_name)->entity;
            $image_item = $media->field_media_image->first();
            $image_alt = (string) ($image_item?->alt ?? '');

            if ($file instanceof FileInterface) {
              $image_uri = $file->getFileUri();

              // Aplicar image style
              $image_style = ImageStyle::load($image_style_name);
              if ($image_style) {
                $image_url = $image_style->buildUrl($image_uri);
              } else {
                // Fallback: imagen original
                $image_url = \Drupal::service('file_url_generator')->generateAbsoluteString($image_uri);
              }
            }
          }
        }
      }

      // Obtener los demás campos
      $item_title = $item_paragraph->hasField('field_titulo')
        ? $item_paragraph->get('field_titulo')->value
        : '';

      $item_date = $item_paragraph->hasField('field_subheading')
        ? $item_paragraph->get('field_subheading')->value
        : '';

      $item_description = $item_paragraph->hasField('field_descripcion')
        ? $item_paragraph->get('field_descripcion')->value
        : '';

      // Agregar al array solo si hay datos válidos
      if ($item_title || $image_url) {
        $slider_items[] = [
          'image' => $image_url,
          'image_alt' => $image_alt,
          'title' => $item_title,
          'date' => $item_date,
          'description' => $item_description,
        ];
      }
    }
  }

  // Pasar los items procesados a la variable del template
  $variables['slider_items'] = $slider_items;

  // También pasar los campos principales
  $variables['heading_title'] = $paragraph->hasField('field_titulo')
    ? $paragraph->get('field_titulo')->value
    : '';

  $variables['heading_subtitle'] = $paragraph->hasField('field_subheading')
    ? $paragraph->get('field_subheading')->value
    : '';
}

function tpms_preprocess_viewfield_item__lista_cartelera__block_4(array &$variables)
{
  if ($view = Views::getView('lista_cartelera')) {
    $view->setDisplay('block_4');
    $view->execute();

    $paragraph = NULL;
    if (!empty($variables['element']['#paragraph']) && $variables['element']['#paragraph'] instanceof ParagraphInterface) {
      $paragraph = $variables['element']['#paragraph'];
    } elseif (!empty($variables['entity']) && $variables['entity'] instanceof ParagraphInterface) {
      $paragraph = $variables['entity'];
    }

    if ($paragraph && $paragraph->hasField('field_heading') && !$paragraph->get('field_heading')->isEmpty()) {
      $variables['title'] = $paragraph->get('field_heading')->value;
    }
  }
}



/**
 * Implements hook_preprocess_paragraph__text_links_image().
 */
function tpms_preprocess_paragraph__text_links_image(array &$variables)
{
  $paragraph = $variables['paragraph'];

  // Procesar título
  $variables['title'] = $paragraph->hasField('field_titulo') && !$paragraph->get('field_titulo')->isEmpty()
    ? $paragraph->get('field_titulo')->value
    : NULL;

  // Procesar imagen
  $variables['imagen_url'] = NULL;
  $variables['imagen_alt'] = '';

  if ($paragraph->hasField('field_imagen') && !$paragraph->get('field_imagen')->isEmpty()) {
    $image_field = $paragraph->get('field_imagen')->first();
    if ($image_field && $image_field->entity) {
      $media = $image_field->entity;
      if ($media instanceof MediaInterface && $media->hasField('field_media_image')) {
        $image_file_field = $media->get('field_media_image')->first();
        if ($image_file_field && $image_file_field->entity) {
          $file = $image_file_field->entity;
          if ($file instanceof FileInterface) {
            $variables['imagen_url'] = $file->createFileUrl();
            $variables['imagen_alt'] = $image_file_field->alt ?? '';
          }
        }
      }
    }
  }

  // Procesar items
  $variables['items'] = [];

  if ($paragraph->hasField('field_item_text_image') && !$paragraph->get('field_item_text_image')->isEmpty()) {
    foreach ($paragraph->get('field_item_text_image') as $item) {
      if (!$item->entity instanceof ParagraphInterface) {
        continue;
      }

      $item_paragraph = $item->entity;

      // Extraer valores del item
      $item_titulo = $item_paragraph->hasField('field_titulo') && !$item_paragraph->get('field_titulo')->isEmpty()
        ? $item_paragraph->get('field_titulo')->value
        : NULL;

      $item_numero_ley = $item_paragraph->hasField('field_subheading') && !$item_paragraph->get('field_subheading')->isEmpty()
        ? $item_paragraph->get('field_subheading')->value
        : NULL;

      // Procesar el botón
      $button_label = NULL;
      $button_url = NULL;
      $archivo_url = NULL;

      if ($item_paragraph->hasField('field_boton') && !$item_paragraph->get('field_boton')->isEmpty()) {
        $boton_field = $item_paragraph->get('field_boton')->first();

        if ($boton_field && $boton_field->entity instanceof ParagraphInterface) {
          $boton_entity = $boton_field->entity;

          // Obtener el título del botón
          if ($boton_entity->hasField('field_titulo') && !$boton_entity->get('field_titulo')->isEmpty()) {
            $button_label = $boton_entity->get('field_titulo')->value;
          }

          // Verificar si tiene un archivo (Media)
          if ($boton_entity->hasField('field_archivo') && !$boton_entity->get('field_archivo')->isEmpty()) {
            $file_id = $boton_entity->get('field_archivo')->target_id;
            $media = Media::load($file_id);

            if ($media && $media->hasField('field_media_file') && !$media->get('field_media_file')->isEmpty()) {
              $media_file_id = $media->get('field_media_file')->target_id;
              $file = File::load($media_file_id);

              if ($file instanceof FileInterface) {
                $archivo_url = $file->createFileUrl();
                // Si no hay título, usar nombre del archivo
                if (!$button_label) {
                  $button_label = $file->getFilename();
                }
              }
            }
          }

          // Verificar si tiene un link (URL) - solo si no hay archivo
          if (!$archivo_url && $boton_entity->hasField('field_link') && !$boton_entity->get('field_link')->isEmpty()) {
            $link_field = $boton_entity->get('field_link')->first();
            if ($link_field && $link_field->getUrl()) {
              $button_url = $link_field->getUrl()->toString();
              // Si no hay título, usar el título del link
              if (!$button_label && $link_field->title) {
                $button_label = $link_field->title;
              }
            }
          }
        }
      }

      // Agregar item al array solo si tiene contenido
      if ($item_titulo || $item_numero_ley || $button_label) {
        $variables['items'][] = [
          'titulo' => $item_titulo,
          'numero_ley' => $item_numero_ley,
          'button_label' => $button_label,
          'button_url' => $button_url,
          'archivo_url' => $archivo_url,
        ];
      }
    }
  }
}
