{#
/**
 * Galería Espacios Item (Molecule)
 *
 * Variables:
 * - item: Object/array with:
 *   - image: Image URL
 *   - alt: Image alt text
 *   - label: Space name
 * - base_class: Base BEM class (default: 'galeria-espacios')
 */
#}

{% set base_class = base_class|default('galeria-espacios') %}

<div class="col-12 col-md-6 col-lg-3 {{ base_class }}__item">
  <div class="{{ base_class }}__card">
    <div class="{{ base_class }}__image-wrapper">
      {% if image %}
        <img
          src="{{ image }}"
          alt="{{ alt|default(label) }}"
          class="{{ base_class }}__image"
          loading="lazy"
        />
      {% endif %}

      <div class="{{ base_class }}__overlay"></div>

      <div class="{{ base_class }}__label-wrapper">
        <span class="{{ base_class }}__label">
          {% if label %}
            {{ label }}
          {% endif %}
        </span>
      </div>
    </div>
  </div>
</div>
