/** 
 * @file
 * Functions to support theming.
 */

function tpms_preprocess_html(&$variables)
{
  $test = 'Xdebug funcionando';
  $node = \Drupal::request()->attributes->get('node');

  $variables['#attached']['library'][] = 'tpms/font-resizer';
  $variables['#attached']['library'][] = 'tpms/menu';
  $variables['#attached']['library'][] = 'tpms/filtros_noticias';
  $variables['#attached']['library'][] = 'tpms/search_expand';
  $variables['#attached']['library'][] = 'tpms/sticky_header_offset';

  if ($node instanceof \Drupal\node\NodeInterface) {
    $token_service = \Drupal::token();
    $text = 'Título del nodo: [node:title]';
    $replaced = $token_service->replace($text, ['node' => $node]);

    $variables['title'] = $replaced;
  }
}

function tpms_preprocess_webform(array &$variables)
{
  $variables['#attached']['library'][] = 'tpms/webforms-js';
}

/**
 * Implements hook_preprocess_HOOK() for page templates.
 */
function tpms_preprocess_page(array &$variables)
{
  $variables['tpms_sections'] = [];

  if (!empty($variables['node']) && $variables['node'] instanceof NodeInterface) {
    $node = $variables['node'];

    if (
      $node->bundle() === 'institucion'
      && $node->hasField('field_secciones')
      && !$node->get('field_secciones')->isEmpty()
    ) {
      $view_mode = 'full';
      $display_id = "node.{$node->bundle()}.{$view_mode}";
      $display = \Drupal::entityTypeManager()
        ->getStorage('entity_view_display')
        ->load($display_id);

      if ($display && ($component = $display->getComponent('field_secciones'))) {
        $variables['tpms_sections'] = $node->get('field_secciones')->view($component);
      } else {
        $variables['tpms_sections'] = $node->get('field_secciones')->view(['label' => 'hidden']);
      }
    }
  }

  $route_match = \Drupal::routeMatch();
  if (!$route_match || $route_match->getRouteName() !== 'entity.node.canonical') {
    return;
  }

  $node = $route_match->getParameter('node');
  if (!($node instanceof NodeInterface) || $node->bundle() !== 'evento') {
    return;
  }

  if (!isset($variables['page']['sidebar']) || !is_array($variables['page']['sidebar'])) {
    $variables['page']['sidebar'] = [];
  }

  $variables['page']['sidebar']['indice_de_eventos'] = [
    '#type' => 'view',
    '#name' => 'indice_de_eventos',
    '#display_id' => 'block_1',
    '#arguments' => [$node->id()],
    '#weight' => -10,
    '#cache' => [
      'contexts' => ['route'],
    ],
  ];
}

/**
 * Implements hook_preprocess_node().
 */
function tpms_preprocess_node(array &$variables)
{
  if (
    empty($variables['node'])
    || !($variables['node'] instanceof NodeInterface)
  ) {
    return;
  }

  /** @var \Drupal\node\Entity\Node $node */
  $node = $variables['node'];

  if (!$node->hasField('field_mostrar_titulo_pagina')) {
    return;
  }

  $value = $node->get('field_mostrar_titulo_pagina')->value;
  $show_title = $value === '1';
  $variables['show_page_title'] = $show_title;

  // Ensure canonical node pages honor show_page_title even when view mode isn't "full".
  $route_match = \Drupal::routeMatch();
  if ($route_match && $route_match->getRouteName() === 'entity.node.canonical') {
    $route_node = $route_match->getParameter('node');
    if ($route_node instanceof NodeInterface && $route_node->id() === $node->id()) {
      $variables['page'] = true;
    }
  }

  if (!$show_title && !empty($variables['page']) && isset($variables['content']['title'])) {
    unset($variables['content']['title']);
  }
}

function tpms_theme_suggestions_page_alter(array &$suggestions, array $variables): void
{
  $current_path = \Drupal::service('path.current')->getPath();
  $alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);

  if (str_starts_with($alias, '/institucion')) {
    $suggestions[] = 'page__institucion';
  }
}
/**
 * Implements hook_preprocess_HOOK() for field templates.
 */
function tpms_preprocess_field(array &$variables)
{
  $element = $variables['element'] ?? [];
  if (($element['#field_name'] ?? '') !== 'title' || ($element['#entity_type'] ?? '') !== 'node') {
    return;
  }

  $node = $element['#object'] ?? NULL;
  if (!($node instanceof NodeInterface)) {
    return;
  }

  $route_match = \Drupal::routeMatch();
  if (!$route_match || $route_match->getRouteName() !== 'entity.node.canonical') {
    return;
  }

  $route_node = $route_match->getParameter('node');
  if (!($route_node instanceof NodeInterface) || $route_node->id() !== $node->id()) {
    return;
  }

  if (!$node->hasField('field_mostrar_titulo_pagina')) {
    return;
  }

  $value = $node->get('field_mostrar_titulo_pagina')->value;
  $show_title = $value === '1';
  $variables['show_page_title'] = $show_title;

  if (!$show_title) {
    $variables['items'] = [];
    $variables['label_hidden'] = TRUE;
    $variables['element']['#access'] = FALSE;
  }
}

/**
 * Implements hook_preprocess_HOOK() for menu-local-tasks templates.
 */
function tpms_preprocess_menu_local_tasks(&$variables)
{
  if (!empty($variables['primary']) && is_array($variables['primary'])) {
    $variables['primary']['#attached']['library'][] = 'tpms/local-tasks-tabs';

    foreach (Element::children($variables['primary']) as $key) {
      $variables['primary'][$key]['#level'] = 'primary';
    }
  }

  if (!empty($variables['secondary']) && is_array($variables['secondary'])) {
    $variables['secondary']['#attached']['library'][] = 'tpms/local-tasks-tabs';

    foreach (Element::children($variables['secondary']) as $key) {
      $variables['secondary'][$key]['#level'] = 'secondary';
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for menu-local-task templates.
 */
function tpms_preprocess_menu_local_task(&$variables)
{
  if (!isset($variables['link']['#options']['attributes']['class'])) {
    $variables['link']['#options']['attributes']['class'] = [];
  }

  $variables['link']['#options']['attributes']['class'][] = 'tabs__link';
  $variables['link']['#options']['attributes']['class'][] = 'js-tabs-link';

  if (!empty($variables['is_active'])) {
    $variables['link']['#options']['attributes']['class'][] = 'is-active';
  }

  if (isset($variables['element']['#level'])) {
    $variables['level'] = $variables['element']['#level'];
  }
}

/**
 * Preprocess region to inject Newsletter block in footer.
 */
function tpms_preprocess_region(array &$variables)
{
  if (($variables['region'] ?? '') !== 'footer') {
    return;
  }

  if (empty($variables['elements']) || !is_array($variables['elements'])) {
    return;
  }

  // Precalcula el logo del footer con image style (solo Drupal).
  if (!isset($variables['elements']['tpms_footer_logo_src'])) {
    $uri = NULL;

    // 1) Preferimos el URI que expone el bloque de branding.
    if (
      isset($variables['elements']['tpms_marcadelsitio_2']['content']['site_logo']['#uri'])
      && is_string($variables['elements']['tpms_marcadelsitio_2']['content']['site_logo']['#uri'])
    ) {
      $uri = $variables['elements']['tpms_marcadelsitio_2']['content']['site_logo']['#uri'];
    }
    // 2) Fallback: settings del theme (consistente entre usuarios).
    else {
      $uri = \Drupal::config('tpms.settings')->get('logo.path');
    }

    // 3) Último fallback: logo resuelto por el tema activo.
    if (!is_string($uri) || $uri === '') {
      $uri = \Drupal::theme()->getActiveTheme()->getLogo();
    }

    if (is_string($uri) && $uri !== '') {
      $uri = str_replace('public://sites/default/files/', 'public://', $uri);
      if (str_starts_with($uri, '/sites/default/files/')) {
        $uri = 'public://' . substr($uri, strlen('/sites/default/files/'));
      }

      $style = ImageStyle::load('logo_footer');
      $variables['elements']['tpms_footer_logo_src'] = $style
        ? $style->buildUrl($uri)
        : $uri;
    }
  }

  $block_storage = \Drupal::entityTypeManager()->getStorage('block_content');
  $block_config_storage = \Drupal::entityTypeManager()->getStorage('block');

  foreach ($variables['elements'] as $key => $element) {
    if (!is_array($element)) {
      continue;
    }

    $plugin_id = NULL;
    if (isset($element['#plugin_id']) && is_string($element['#plugin_id'])) {
      $plugin_id = $element['#plugin_id'];
    } elseif (isset($element['#configuration']['id']) && is_string($element['#configuration']['id'])) {
      $plugin_id = $element['#configuration']['id'];
    } elseif (is_string($key) && $key === 'tpms_newsletter') {
      $block_config = $block_config_storage->load($key);
      if ($block_config) {
        $plugin_id = $block_config->getPluginId();
      }
    }

    if (!is_string($plugin_id) || $plugin_id === '') {
      continue;
    }

    $plugin_id = (string) $plugin_id;

    // Simplenews
    if (
      $plugin_id === 'simplenews_subscription_block'
      || str_starts_with($plugin_id, 'simplenews_subscription_block:')
      || (is_string($key) && $key === 'tpms_simplenewssubscription')
    ) {
      $variables['elements']['tpms_newsletter_form'] ??= $element;
      unset($variables['elements'][$key]);
      continue;
    }

    // Block content: newsletter
    if (str_starts_with($plugin_id, 'block_content:')) {
      $uuid = substr($plugin_id, 14);
      if (!$uuid) {
        continue;
      }

      $found = $block_storage->loadByProperties(['uuid' => $uuid]);
      if (!$found) {
        continue;
      }

      $block = reset($found);
      if ($block->bundle() !== 'newsletter') {
        continue;
      }

      if ($block->hasField('field_titulo') && !$block->get('field_titulo')->isEmpty()) {
        $variables['elements']['tpms_newsletter_title'] =
          $block->get('field_titulo')->view(['label' => 'hidden']);
      }

      if ($block->hasField('field_description') && !$block->get('field_description')->isEmpty()) {
        $variables['elements']['tpms_newsletter_description'] =
          $block->get('field_description')->view(['label' => 'hidden']);
      }

      unset($variables['elements'][$key]);
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for
 * viewfield-item--field-reference--noticias-destacadas.html.twig.
 */
function tpms_preprocess_viewfield_item__field_reference__noticias_destacadas(array &$variables)
{
  if ($view = Views::getView('noticias_destacadas')) {
    $view->setDisplay($variables['element']['#display_id']);
    $view->execute();

    $items = [];
    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      $image_url = NULL;

      if ($node->hasField('field_imagen_noticia') && !$node->get('field_imagen_noticia')->isEmpty()) {
        /** @var MediaInterface $media */
        $media = $node->get('field_imagen_noticia')->entity;

        if (
          $media instanceof MediaInterface
          && $media->hasField('field_media_image')
          && !$media->get('field_media_image')->isEmpty()
        ) {

          /** @var FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();
            /** @var ImageStyle $style */
            $style = ImageStyle::load('full');
            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      $items[] = [
        'title' => $node->label(),
        'url'   => $node->toUrl()->toString(),
        'image' => $image_url,
      ];
    }

    $variables['slider_items'] = $items;

    $display = $view->display_handler;
    $use_more       = $display->getOption('use_more');
    $link_display   = $display->getOption('link_display');
    $custom_path    = $display->getOption('link_url');
    $more_text      = $display->getOption('use_more_text');

    if ($use_more && $link_display === 'custom_url' && !empty($custom_path)) {
      // Construye la URL (interna o externa).
      $variables['view_more_url']  = Url::fromUri('internal:' . $custom_path)->toString();
      $variables['view_more_text'] = $more_text;
    }
  }
}

function tpms_preprocess_paragraph__imagen_texto(&$variables)
{
  $paragraph = $variables['paragraph'];

  // Título
  $variables['tpms_titulo'] = !$paragraph->get('field_titulo')->isEmpty()
    ? $paragraph->field_titulo->value
    : NULL;

  // Formato de imagen (cuadrada o panorámica)
  // $variables['tpms_image_format'] = (
  //   !$paragraph->get('field_imagen_con_formato')->isEmpty() &&
  //   !$paragraph->field_imagen_con_formato->entity->get('field_imagen_a_la_derecha')->isEmpty() &&
  //   $paragraph->field_imagen_con_formato->entity->field_imagen_a_la_derecha->value == 1
  // ) ? 'panoramica' : 'cuadrada';

  // Imagen
  $variables['tpms_imagen'] = $variables['content']['field_imagen'];

  // Posición de imagen
  $variables['tpms_image_position'] = (
    !$paragraph->get('field_imagen_a_la_derecha')->isEmpty() &&
    $paragraph->field_imagen_a_la_derecha->value == 1
  ) ? 'derecha' : 'izquierda';

  // Lugar
  $variables['tpms_lugar'] = !$paragraph->get('field_lugar')->isEmpty()
    ? $paragraph->field_lugar->value
    : NULL;

  // Categorías (array de nombres)
  $categorias = [];
  if (!$paragraph->get('field_categoria')->isEmpty()) {
    foreach ($paragraph->field_categoria as $term_item) {
      if ($term_item->entity) {
        $categorias[] = $term_item->entity->label();
      }
    }
  }
  $variables['tpms_categorias'] = $categorias;

  // Botón: solo si tiene texto Y URL
  if (
    !$paragraph->get('field_boton')->isEmpty() &&
    $paragraph->field_boton->entity
  ) {
    $boton = $paragraph->field_boton->entity;

    // Verificamos que field_link tenga contenido válido
    if (
      !$boton->get('field_link')->isEmpty() &&
      !empty($boton->field_link->title) &&
      $boton->field_link->first()->getUrl()
    ) {
      $variables['tpms_color_button'] = $boton->field_color_de_fondo->color;
      $variables['tpms_texto_imagen_button_content'] = $boton->field_link->title;
      $variables['texto_imagen_button_url'] = $boton->field_link->first()->getUrl()->toString();
    }
  }

  // Contenido procesado
  if (!$paragraph->get('field_contenido')->isEmpty()) {
    $variables['tpms_contenido'] = [
      '#type' => 'processed_text',
      '#text' => $paragraph->field_contenido->value,
      '#format' => $paragraph->field_contenido->format,
    ];
  }

  if (!$paragraph->get('field_rango_de_fecha')->isEmpty()) {
    $fecha_raw = $paragraph->field_rango_de_fecha->daterangepicker;

    if (!empty($fecha_raw)) {
      [$inicio_raw, $fin_raw] = explode(' - ', $fecha_raw);

      $inicio = \DateTime::createFromFormat('m/d/Y h:i A', $inicio_raw);
      $fin = \DateTime::createFromFormat('m/d/Y h:i A', $fin_raw);

      // Verificar si inicio y fin son el mismo día (misma fecha exacta)
      $mismo_dia = (
        $inicio && $fin &&
        $inicio->format('Y-m-d') === $fin->format('Y-m-d')
      );

      if ($inicio && $fin && !$mismo_dia) {
        $meses = [
          1 => 'enero',
          2 => 'febrero',
          3 => 'marzo',
          4 => 'abril',
          5 => 'mayo',
          6 => 'junio',
          7 => 'julio',
          8 => 'agosto',
          9 => 'septiembre',
          10 => 'octubre',
          11 => 'noviembre',
          12 => 'diciembre',
        ];

        $formateado = $inicio->format('j') . ' de ' . $meses[(int)$inicio->format('n')];

        if (
          $inicio->format('n') != $fin->format('n') ||
          $inicio->format('j') != $fin->format('j')
        ) {
          $formateado .= ' - ' . $fin->format('j') . ' de ' . $meses[(int)$fin->format('n')];
        }

        $formateado .= ' ' . $fin->format('Y');

        $variables['tpms_fecha_rango'] = $formateado;
      }
    }
  }
}

function tpms_preprocess_paragraph__titulo_de_pagina(&$variables)
{
  $paragraph = $variables['paragraph'] ?? NULL;
  if (!$paragraph || !method_exists($paragraph, 'getParentEntity')) {
    return;
  }

  $parent = $paragraph->getParentEntity();
  if (!($parent instanceof NodeInterface)) {
    return;
  }

  if (!$parent->hasField('field_mostrar_titulo_pagina')) {
    return;
  }

  $value = $parent->get('field_mostrar_titulo_pagina')->value;
  if ($value !== '1') {
    if (isset($variables['elements'])) {
      $variables['elements']['#access'] = FALSE;
    }
    $variables['#access'] = FALSE;
  }
}

/**
 * Preprocess for viewfield (wrapper).
 * Aquí SÍ existe $variables['entity'] (el Paragraph).
 */
function tpms_preprocess_viewfield(array &$variables): void
{
  $host = $variables['entity'] ?? NULL;
  if (!$host instanceof ParagraphInterface) {
    return;
  }

  // Inyectar el paragraph host dentro de cada item para que lo lea viewfield_item.
  if (!empty($variables['items']) && is_array($variables['items'])) {
    foreach ($variables['items'] as $delta => &$item) {
      if (is_array($item) && isset($item['element']) && is_array($item['element'])) {
        $item['element']['#host_entity'] = $host;
      } elseif (is_array($item)) {
        $item['#host_entity'] = $host;
      }
    }
  }
}
/**
 * Implements hook_preprocess_HOOK() for
 * viewfield-item--ultimos-eventos.html.twig.
 */
function tpms_preprocess_viewfield_item__ultimos_eventos(array &$variables)
{
  if ($view = Views::getView('ultimos_eventos')) {
    $view->setDisplay('block_1');
    $view->execute();

    $items = [];
    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      $image_url = NULL;

      $image_alt = '';

      if ($node->hasField('field_imagen') && !$node->get('field_imagen')->isEmpty()) {
        /** @var \Drupal\media\MediaInterface $media */
        $media = $node->get('field_imagen')->entity;

        if (
          $media instanceof \Drupal\media\MediaInterface
          && $media->hasField('field_media_image')
          && !$media->get('field_media_image')->isEmpty()
        ) {
          $image_alt = (string) $media->get('field_media_image')->alt;

          /** @var \Drupal\file\FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof \Drupal\file\FileInterface) {
            $uri = $file->getFileUri();

            /** @var \Drupal\image\Entity\ImageStyle $style */
            $style = \Drupal\image\Entity\ImageStyle::load('cartelera_418x427');
            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      /** @var \Drupal\node\Entity\Node $node */
      $date_items = $node->get('field_fechas_evento'); // FieldItemListInterface

      if (!$date_items->isEmpty()) {
        /** @var \Drupal\smart_date\Plugin\Field\FieldType\SmartDateItem $first_item */
        $first_item = $date_items->first();
        $start_timestamp = $first_item->value;

        $count = $date_items->count();
        /** @var \Drupal\smart_date\Plugin\Field\FieldType\SmartDateItem $last_item */
        $last_item = $date_items->get($count - 1);
        $end_timestamp = $last_item->end_value ?: $last_item->value;

        /** @var \Drupal\Core\Datetime\DateFormatterInterface $df */
        $df = \Drupal::service('date.formatter');

        $start_formatted = $df->format($start_timestamp, 'custom', 'j \d\e F');
        $end_formatted   = $df->format($end_timestamp,   'custom', 'j \d\e F');
        $year            = $df->format($end_timestamp,   'custom', 'Y');

        if ($start_formatted === $end_formatted) {
          $finish_date = "{$start_formatted} {$year}";
        } else {
          $finish_date = "{$start_formatted} – {$end_formatted} {$year}";
        }
      } else {
        $finish_date = NULL;
      }

      /** @var \Drupal\taxonomy\Entity\Term[] $terms */
      /** @var \Drupal\Core\Field\EntityReferenceFieldItemList $terms */

      if ($node->get('field_institucion')->entity) {
        $categoria = $node->get('field_institucion')->entity->title->value;
      }


      $link_field = $node->get('field_enlace_externo')->first();
      $external_link = [];
      if ($link_field) {
        $external_link = [
          'uri' => $link_field->uri,
          'title' => $link_field->title
        ];
      }

      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
      /** @var NodeInterface|null $institucion */
      $institucion = ($node->hasField('field_institucion') && !$node->get('field_institucion')->isEmpty())
        ? $node->field_institucion->entity
        : null;
      $institucion_title = ($institucion && $institucion->hasField('title') && !$institucion->get('title')->isEmpty())
        ? $institucion->title->value
        : '';

      $large_title = $institucion_title ? $node->label() . ' | ' . $institucion_title : $node->label();
      $lugar = $node->get('field_lugar')->value;

      $items[] = [
        'large_title' => $large_title,
        'url'   => $node->toUrl()->toString(),
        'image' => $image_url,
        'date' => $finish_date,
        'lugar' => $lugar,
        'categoria' => $categoria,
        'external_link' => $external_link,
        'node_url' => $node_url,
        'image_alt' => $image_alt,
      ];
    }
    $variables['slider_items'] = $items;


    $display = $view->display_handler;
    $use_more       = $display->getOption('use_more');
    $link_display   = $display->getOption('link_display');
    $custom_path    = $display->getOption('link_url');
    $more_text      = $display->getOption('use_more_text');

    // if ($use_more && $link_display === 'custom_url' && !empty($custom_path)) {
    //   $variables['view_more_url']  = Url::fromUri('internal:' . $custom_path)->toString();
    //   $variables['view_more_text'] = $more_text;
    // }
    /**
     * ===== Sacar datos desde el paragraph (title, description, link) =====
     * Host entity del viewfield-item.
     */
    $host = $variables['element']['#host_entity'] ?? NULL;
    // Fallback por si la estructura cambia.
    if (!$host && isset($variables['element']['#content']['#host_entity'])) {
      $host = $variables['element']['#content']['#host_entity'];
    }

    if ($host instanceof ParagraphInterface) {

      // Título
      $variables['heading_title'] = (!$host->get('field_heading')->isEmpty())
        ? $host->get('field_heading')->value
        : '';

      // Descripción (texto largo)
      $variables['heading_description'] = (!$host->get('field_description')->isEmpty())
        ? $host->get('field_description')->value
        : '';

      // Botón (link)
      $variables['button_text'] = '';
      $variables['button_url'] = '';

      if ($host->hasField('field_link') && !$host->get('field_link')->isEmpty()) {
        $link = $host->get('field_link')->first();
        $variables['button_text'] = $link->title ?? '';
        $variables['button_url'] = $link->getUrl()->toString();
      }
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for
 * viewfield-item--lista-de-fondos-concursables.html.twig.
 */
function tpms_preprocess_viewfield_item__lista_de_fondos_concursables(array &$variables)
{
  if ($view = Views::getView('lista_de_fondos_concursables')) {
    $view->setDisplay($variables["content"]['#display_id']);
    $view->execute();

    /** @var \Drupal\Core\Render\RendererInterface $renderer */
    $renderer = \Drupal::service('renderer');

    $form_state = (new FormState())
      ->setStorage([
        'view' => $view,
        'display' => &$view->display_handler->display,
        'rerender' => TRUE,
      ])
      ->setMethod('get')
      ->setAlwaysProcess()
      ->disableRedirect();
    $form_state->set('rerender', NULL);
    $form = \Drupal::formBuilder()->buildForm(
      '\Drupal\views\Form\ViewsExposedForm',
      $form_state
    );

    $pager_render_array = $view->pager->render($view->pager->options);
    $pager_html = $renderer->renderRoot($pager_render_array);

    $items = [];
    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      $title = $node->label();
      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
      $summary = '';
      if ($node->hasField('body') && !$node->get('body')->isEmpty()) {
        $body_item = $node->get('body')->first();
        $raw_text = !empty($body_item->summary) ? $body_item->summary : $body_item->value;
        if (!empty($raw_text)) {
          $plain_text = trim(strip_tags($raw_text));
          $summary = Unicode::truncate($plain_text, 200, TRUE, TRUE);
        }
      }

      $items[] = [
        'node' => $node,
        'title' => $title,
        'url' => $node_url,
        'summary' => $summary,
      ];
    };

    $variables['items'] = $items;
    $variables['pager_html'] = $pager_html;
    $variables['exposed_form'] = $form;
  }
}

function tpms_preprocess_paragraph__artists_section(array &$variables)
{
  $paragraph = $variables['paragraph'] ?? NULL;
  if (!$paragraph) {
    return;
  }

  $variables['section_title'] = $paragraph->hasField('field_titulo') && !$paragraph->get('field_titulo')->isEmpty()
    ? $paragraph->get('field_titulo')->value
    : NULL;

  $variables['section_description'] = $paragraph->hasField('field_description') && !$paragraph->get('field_description')->isEmpty()
    ? $paragraph->get('field_description')->value
    : NULL;

  $variables['section_has_margin'] = TRUE;
  if ($paragraph->hasField('field_margen_inferior') && !$paragraph->get('field_margen_inferior')->isEmpty()) {
    $variables['section_has_margin'] = (bool) $paragraph->get('field_margen_inferior')->value;
  }

  $items = [];
  if ($paragraph->hasField('field_artistas') && !$paragraph->get('field_artistas')->isEmpty()) {
    foreach ($paragraph->get('field_artistas')->referencedEntities() as $item) {
      $title = $item->hasField('field_titulo') && !$item->get('field_titulo')->isEmpty()
        ? $item->get('field_titulo')->value
        : '';

      $url = '#';
      if ($item->hasField('field_link') && !$item->get('field_link')->isEmpty()) {
        try {
          $url = $item->get('field_link')->first()->getUrl()->toString();
        } catch (\Throwable $e) {
          $url = '#';
        }
      }

      $image = NULL;
      $image_alt = '';
      if ($item->hasField('field_imagen') && !$item->get('field_imagen')->isEmpty()) {
        $media = $item->get('field_imagen')->entity;
        if ($media && $media->hasField('field_media_image') && !$media->get('field_media_image')->isEmpty()) {
          $image_item = $media->get('field_media_image')->first();
          $image_alt = (string) ($image_item?->alt ?? '');
          $file = $media->get('field_media_image')->entity;
          if ($file) {
            $uri = $file->getFileUri();
            $style = ImageStyle::load('artists_section_342x419');
            $image = $style
              ? $style->buildUrl($uri)
              : \Drupal::service('file_url_generator')->generateString($uri);
          }
        }
      }

      $items[] = [
        'title' => $title,
        'url' => $url,
        'image' => $image,
        'image_alt' => $image_alt,
      ];
    }
  }

  $variables['artists'] = $items;
}

function tpms_preprocess_paragraph__cta(array &$variables)
{
  $paragraph = $variables['paragraph'];

  // Inicialización segura
  $variant = $paragraph->hasField('field_variante_de_cta') && !$paragraph->get('field_variante_de_cta')->isEmpty()
    ? $paragraph->get('field_variante_de_cta')->value
    : '';

  $variables['cta_has_margin'] = TRUE;
  if (
    $variant === 'cta_basico_oscuro' &&
    $paragraph->hasField('field_margen_inferior') &&
    !$paragraph->get('field_margen_inferior')->isEmpty()
  ) {
    $variables['cta_has_margin'] = (bool) $paragraph->get('field_margen_inferior')->value;
  }

  // Mapeo de variantes a modificadores
  $modifiers_map = [
    'cta_basico' => 'default',
    'cta_basico_oscuro' => 'dark',
    'cta_oscuro_con_imagen' => 'rectangular',
  ];
  $variables['cta_modifier'] = $modifiers_map[$variant] ?? 'default';

  // Título
  $variables['cta_title'] = $paragraph->hasField('field_titulo') && !$paragraph->get('field_titulo')->isEmpty()
    ? $paragraph->get('field_titulo')->value
    : NULL;

  // Descripción
  $variables['cta_description'] = $paragraph->hasField('field_description') && !$paragraph->get('field_description')->isEmpty()
    ? $paragraph->get('field_description')->value
    : NULL;

  // Subheading (para tagline)
  $button_content_tag = $paragraph->hasField('field_subheading') && !$paragraph->get('field_subheading')->isEmpty()
    ? $paragraph->get('field_subheading')->value
    : NULL;

  $variables['cta_button_content_tag'] = $button_content_tag;

  if (!empty($button_content_tag)) {
    $variables['tagline'] = [
      'tagline' => true,
      'button_modifiers_tag' => ['tertiary-border'],
      'button_icon_tag' => [
        'icon_name' => 'tag-seccion',
        'icon_height' => 32,
        'icon_width' => 32,
      ],
    ];
  }

  // Determinar modifiers del botón
  if (in_array($variant, ['cta_basico_oscuro'])) {
    $button_modifier = ['secondary'];
  } elseif (in_array($variant, ['cta_oscuro_con_imagen'])) {
    $button_modifier = ['tertiary-border'];
  } else {
    $button_modifier = ['primary', 'medium'];
  }

  // Botón
  if (
    $paragraph->hasField('field_boton') &&
    !$paragraph->get('field_boton')->isEmpty()
  ) {
    $variables['cta_buttons'] = []; // Array para almacenar todos los botones

    foreach ($paragraph->get('field_boton') as $item) {
      if (!$item->entity instanceof \Drupal\Core\Entity\EntityInterface) {
        continue;
      }

      $boton = $item->entity;
      $button_data = [];

      // Procesar archivo o enlace si existe
      if (
        $boton->hasField('field_archivo') &&
        !$boton->get('field_archivo')->isEmpty()
      ) {
        $file_id = $boton->field_archivo->target_id;
        $media = \Drupal\media\Entity\Media::load($file_id);

        if ($media && $media->hasField('field_media_file')) {
          $file_id = $media->field_media_file->target_id;
          $file = \Drupal\file\Entity\File::load($file_id);

          if ($file) {
            if ($button_modifier == ['tertiary']) {
              $icon_name = 'download';
              $button_modifier = ['tertiary', 'medium'];
            } else {
              $icon_name = 'download';
              $button_modifier = ['tertiary', 'medium'];
            }

            if (!$boton->field_titulo->isEmpty()) {
              $button_name = $boton->field_titulo->value;
            } else {
              $button_name = $file->getFilename();
            }

            $button_data = [
              'button_content' => $button_name,
              'button_url' => $file->createFileUrl(),
              'button_modifiers' => $button_modifier,
              'button_icon' => [
                'icon_name' => $icon_name,
                'icon_height' => 24,
                'icon_width' => 24,
                'directory' => ' '
              ],
              'button_is_download' => true
            ];
          }
        }
      } elseif (
        $boton->hasField('field_link') &&
        !$boton->get('field_link')->isEmpty() &&
        $boton->field_link->first()->getUrl()
      ) {
        if ($button_modifier == ['tertiary-border']) {
          $button_icon = [
            'icon_name' => 'mini_right',
            'icon_height' => 24,
            'icon_width' => 24,
            'directory' => ' '
          ];
        } else {
          $button_icon = [];
        }

        $button_data = [
          'button_content' => $boton->field_link->title,
          'button_url' => $boton->field_link->first()->getUrl()->toString(),
          'button_modifiers' => $button_modifier,
          'button_icon' => $button_icon,
        ];
      }

      if (!empty($button_data)) {
        $variables['cta_buttons'][] = $button_data;
      }
    }
  }

  // Imagen
  if ($variables['content']['field_imagen']) {
    $variables['cta_image'] = $variables['content']['field_imagen'];
  }
}

function tpms_views_pre_render(ViewExecutable $view)
{
  $datatables_views = [
    'lista_de_documentos',
    'lista_funcionarios',
    'transparencia',
  ];

  if (in_array($view->id(), $datatables_views, TRUE)) {

    $view->element['#attached']['library'][] = 'tpms/datatables';
  }
}

/**
 * Implements hook_preprocess_HOOK() for views_view.
 */
function tpms_preprocess_views_view(&$variables)
{
  $view = $variables['view'];
  if ($variables['view']->id() === 'lista_de_documentos') {
    $variables['#attached']['library'][] = 'tpms/datatables';
  }
  if ($variables['view']->id() === 'lista_de_terminos_transparencia') {
    $variables['#attached']['library'][] = 'tpms/tree_menu';
  }
  if ($view->id() === 'indice_de_eventos') {
    $variables['#attached']['library'][] = 'tpms/indice_eventos';
  }
  if ($view->id() === 'transparencia') {
    $variables['#attached']['library'][] = 'tpms/datatables';
    // Obtenemos el primer argumento contextual (el TID).
    if (!empty($view->args[0]) && is_numeric($view->args[0])) {
      $tid = $view->args[0];
      // Cargamos la entidad del término.
      $term = \Drupal::entityTypeManager()
        ->getStorage('taxonomy_term')
        ->load($tid);
      if ($term) {
        // Hacemos disponible el nombre para Twig.
        $variables['term_name'] = $term->getName();
      }
    }
  }
}

/**
 * Implements hook_theme_suggestions_HOOK_alter() for views_view.
 *
 * Añade una sugerencia específica para la vista 'transparencia' y su page_1.
 */
function tpms_theme_suggestions_views_view_alter(array &$suggestions, array $variables)
{
  /** @var \Drupal\views\ViewExecutable $view */
  $view = $variables['view'];

  $view_id = $view->id();
  $display_id = $view->current_display;

  // Sugerencias genéricas para todas las vistas
  $suggestions[] = 'views_view__' . $view_id;
  $suggestions[] = 'views_view__' . $view_id . '__' . $display_id;

  // Sugerencias específicas (mantener compatibilidad)
  if ($view->id() === 'transparencia' && $view->current_display === 'page_1') {
    $suggestions[] = 'views_view__transparencia__page_1';
  }

  if ($view_id === 'programas_artisticos' && $display_id === 'block_1') {
    $suggestions[] = 'views_view__programas_artisticos__block_1';
  }
}

/**
 * Implements hook_preprocess_HOOK() for
 * viewfield-item--lista-de-noticias--block-1.html.twig.
 */
function tpms_preprocess_viewfield_item__noticias_y_comunicados(array &$variables)
{

  if ($view = Views::getView($variables['content']['#name'])) {
    $view->setDisplay($variables['content']['#display_id']);
    $view->execute();

    $items = [];
    $featured = null;

    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $index => $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      $image_url = NULL;
      $image_alt = '';

      if ($node->hasField('field_imagen_noticia') && !$node->get('field_imagen_noticia')->isEmpty()) {
        /** @var MediaInterface $media */
        $media = $node->get('field_imagen_noticia')->entity;

        if (
          $media instanceof MediaInterface
          && $media->hasField('field_media_image')
          && !$media->get('field_media_image')->isEmpty()
        ) {
          $image_item = $media->get('field_media_image')->first();
          if ($image_item) {
            $image_alt = (string) $image_item->alt;
          }

          /** @var FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();
            /** @var ImageStyle $style */
            if ($index === 0) {
              $style = ImageStyle::load('noticia_952x472');
            } else {
              $style = ImageStyle::load('card_noticia');
            }

            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      $title = $node->label();
      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();

      $formatted_date = \Drupal::service('date.formatter')
        ->format($node->created->value, 'custom', 'F j, Y');

      if ($node->field_categorias_de_noticias->target_id) {
        $term = \Drupal\taxonomy\Entity\Term::load($node->field_categorias_de_noticias->target_id);
        $category_name = $term->getName();
      }

      $item_data = [
        'image' => $image_url,
        'image_alt' => $image_alt,
        'title' => $title,
        'date' => $formatted_date,
        'category' => $category_name,
        'summary' =>  $node->get('body')->summary,
        'url' => $node_url
      ];

      if ($index === 0) {
        $featured = $item_data;
      } else {
        $items[] = $item_data;
      }
    };

    $variables['featured'] = $featured;
    $variables['noticias_items'] = $items;
  }

  $paragraph = NULL;
  if (!empty($variables['element']['#paragraph']) && $variables['element']['#paragraph'] instanceof ParagraphInterface) {
    $paragraph = $variables['element']['#paragraph'];
  } elseif (!empty($variables['entity']) && $variables['entity'] instanceof ParagraphInterface) {
    $paragraph = $variables['entity'];
  }

  if ($paragraph && $paragraph->hasField('field_link') && !$paragraph->get('field_link')->isEmpty()) {
    $link_item = $paragraph->get('field_link')->first();
    if ($link_item && $link_item->getUrl()) {
      $variables['button_url'] = $link_item->getUrl()->toString();
      if (!empty($link_item->title)) {
        $variables['button_text'] = $link_item->title;
      }
    }
  }

  if ($paragraph && $paragraph->hasField('field_heading') && !$paragraph->get('field_heading')->isEmpty()) {
    $variables['noticias_title'] = $paragraph->get('field_heading')->value;
  }
}

/**
 * Implements hook_preprocess_node__evento().
 */
function tpms_preprocess_node__evento(array &$variables)
{
  if ($variables['view_mode'] !== 'full') {
    return;
  }

  /** @var \Drupal\node\Entity\Node $node */
  $node = $variables['node'] ?? NULL;
  if (!($node instanceof NodeInterface)) {
    return;
  }

  $variables['evento_title'] = $node->label();

  $variables['evento_description'] = NULL;
  if ($node->hasField('field_tabla_informativa') && !$node->get('field_tabla_informativa')->isEmpty()) {
    $variables['evento_description'] = [
      '#type' => 'processed_text',
      '#text' => $node->field_tabla_informativa->value,
      '#format' => $node->field_tabla_informativa->format,
    ];
  }

  $variables['evento_date_range'] = NULL;
  if ($node->hasField('field_fechas_evento') && !$node->get('field_fechas_evento')->isEmpty()) {
    $date_items = $node->get('field_fechas_evento');
    $first_item = $date_items->first();
    $last_item = $date_items->get($date_items->count() - 1);

    $start_timestamp = $first_item->value;
    $end_timestamp = $last_item->end_value ?: $last_item->value;

    $df = \Drupal::service('date.formatter');
    $start_formatted = $df->format($start_timestamp, 'custom', 'j \\d\\e F');
    $end_formatted = $df->format($end_timestamp, 'custom', 'j \\d\\e F');
    $year = $df->format($end_timestamp, 'custom', 'Y');

    if ($start_formatted === $end_formatted) {
      $variables['evento_date_range'] = "{$start_formatted} {$year}";
    } else {
      $variables['evento_date_range'] = "{$start_formatted} - {$end_formatted} {$year}";
    }
  }

  $variables['evento_lugar'] = NULL;
  if ($node->hasField('field_lugar') && !$node->get('field_lugar')->isEmpty()) {
    $variables['evento_lugar'] = $node->get('field_lugar')->value;
  }

  $variables['evento_institucion'] = NULL;
  if ($node->hasField('field_institucion') && !$node->get('field_institucion')->isEmpty()) {
    $institution = $node->get('field_institucion')->entity;
    if ($institution instanceof EntityInterface) {
      $variables['evento_institucion'] = $institution->label();
    }
  }

  $variables['evento_links'] = [];
  if ($node->hasField('field_enlace_externo') && !$node->get('field_enlace_externo')->isEmpty()) {
    foreach ($node->get('field_enlace_externo') as $link_item) {
      $url = $link_item->getUrl();
      if (!$url) {
        continue;
      }
      $value = $link_item->getValue();
      $variables['evento_links'][] = [
        'title' => $value['title'] ?? $url->toString(),
        'url' => $url->toString(),
        'target' => $value['options']['attributes']['target'] ?? '_self',
      ];
    }
  }

  $variables['evento_image'] = NULL;
  if ($node->hasField('field_imagen') && !$node->get('field_imagen')->isEmpty()) {
    $media = $node->get('field_imagen')->entity;
    if (
      $media instanceof MediaInterface
      && $media->hasField('field_media_image')
      && !$media->get('field_media_image')->isEmpty()
    ) {
      $file = $media->get('field_media_image')->entity;
      if ($file instanceof FileInterface) {
        $uri = $file->getFileUri();
        $style = ImageStyle::load('eventosingle');
        $image_url = $style
          ? $style->buildUrl($uri)
          : \Drupal::service('file_url_generator')->generateString($uri);

        $variables['evento_image'] = [
          'src' => $image_url,
          'alt' => $media->field_media_image->alt ?? '',
        ];
      }
    }
  }
}

/**
 * Implements hook_preprocess_node__noticia().
 */
function tpms_preprocess_node__noticia(array &$variables)
{

  // Solo en full view mode.
  if ($variables['view_mode'] !== 'full') {
    return;
  }
  /** @var \Drupal\node\Entity\Node $node */
  $node = $variables['node'];
  // Fecha formateada: "28 de Enero"
  $variables['noticia_date'] = \Drupal::service('date.formatter')
    ->format($node->getCreatedTime(), 'custom', 'j \\d\\e F', null, $node->language()->getId());


  // Carga tu vista "lista_de_noticias" display "block_1".
  if ($view = Views::getView('lista_de_noticias')) {
    $view->setDisplay('block_1');
    $view->execute();

    // Lista de notiicas y comunicados (cards)
    $items = [];
    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $index => $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      $image_url = NULL;

      if ($node->hasField('field_imagen_noticia') && !$node->get('field_imagen_noticia')->isEmpty()) {
        /** @var MediaInterface $media */
        $media = $node->get('field_imagen_noticia')->entity;

        if (
          $media instanceof MediaInterface
          && $media->hasField('field_media_image')
          && !$media->get('field_media_image')->isEmpty()
        ) {

          /** @var FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();

            /** @var ImageStyle $style */
            $style = ImageStyle::load('card_noticia');

            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      $title = $node->label();
      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();

      $formatted_date = \Drupal::service('date.formatter')
        ->format($node->created->value, 'custom', 'F j, Y');

      if ($node->field_categorias_de_noticias->target_id) {
        $term = \Drupal\taxonomy\Entity\Term::load($node->field_categorias_de_noticias->target_id);
        $category_name = $term->getName();
      }

      $item_data = [
        'image' => $image_url,
        'title' => $title,
        'date' => $formatted_date,
        'category' => $category_name,
        'summary' =>  $node->get('body')->summary,
        'url' => $node_url
      ];

      $items[] = $item_data;
    };

    $variables['noticias_items'] = $items;
  }
}

/**
 * Implements hook_preprocess_node__efemeride().
 */
function tpms_preprocess_node__efemeride(array &$variables)
{
  // Solo en full view mode.
  if ($variables['view_mode'] !== 'full') {
    return;
  }

  // Carga la view.
  if ($view = Views::getView('efemerides')) {
    $view->setDisplay('block_4');
    $view->execute();

    $display = $view->display_handler;

    // 2) Comprueba si el "Ver todas" está activo:
    if ($display->getOption('use_more')) {
      // 3) Toma el texto y la ruta tal cual lo configuraste:
      $text = $display->getOption('use_more_text');
      $path = $display->getOption('link_url');

      // 4) Construye la URL (interna o externa):
      if (preg_match('#^https?://#', $path)) {
        $url = Url::fromUri($path);
      } else {
        $url = Url::fromUserInput($path);
      }

      // 5) Genera el render array del link:
      $link = Link::fromTextAndUrl($text, $url)->toRenderable();
      // (Opcional) añade clases CSS:
      $link['#attributes']['class'] = ['button', 'button--small'];

      // 6) Pásalo a Twig:
      $variables['efemerides_more_link'] = $link;
    }


    $items = [];

    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $row) {
      /** @var NodeInterface $node */
      $node = $row->_entity;

      // 1) Título y URL
      $title    = $node->label();
      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();

      // 2) Día: extraemos el valor integer
      $day = $node->get('field_dia')->value;

      // 3) Mes: extraemos el valor y luego su label desde allowed_values
      $mes_value = $node->get('field_mes')->value;
      // allowed_values es un array [1 => 'Enero', 2 => 'Febrero', ...]
      $allowed = $node
        ->get('field_mes')
        ->getFieldDefinition()
        ->getSetting('allowed_values');
      $month_label = isset($allowed[$mes_value]) ? $allowed[$mes_value] : $mes_value;

      // 4) Construimos la fecha legible
      $date = $day . ' de ' . $month_label;

      $items[] = [
        'title' => $title,
        'day'  => $day,
        'month' => $month_label,
        'url'   => $node_url,
      ];
    }

    // Pasamos al template
    $variables['efemerides_items'] = $items;
  }
}

function tpms_preprocess_viewfield_item__lista_de_noticias__block_4(array &$variables)
{
  if ($view = Views::getView('lista_de_noticias')) {
    $view->setDisplay('block_4');
    $view->execute();

    $items = [];

    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $index => $row) {
      /** @var \Drupal\node\NodeInterface $node */
      $node = $row->_entity;

      $image_url = NULL;

      if ($node->hasField('field_imagen_noticia') && !$node->get('field_imagen_noticia')->isEmpty()) {
        /** @var \Drupal\media\MediaInterface $media */
        $media = $node->get('field_imagen_noticia')->entity;

        if (
          $media instanceof MediaInterface &&
          $media->hasField('field_media_image') &&
          !$media->get('field_media_image')->isEmpty()
        ) {
          /** @var \Drupal\file\FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();
            $style = ImageStyle::load('card_noticia');
            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      $title = $node->label();
      $node_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
      $formatted_date = \Drupal::service('date.formatter')->format($node->getCreatedTime(), 'custom', 'F j, Y');

      $category_name = '';
      if (!$node->get('field_categorias_de_noticias')->isEmpty()) {
        $term = \Drupal\taxonomy\Entity\Term::load($node->get('field_categorias_de_noticias')->target_id);
        if ($term) {
          $category_name = $term->getName();
        }
      }
      $card_alt =  $media->field_media_image->alt;
      $item_data = [
        'card__image__src' => $image_url,
        'card__title' => $title,
        'card__date' => $formatted_date,
        'card__category' => $category_name,
        'card__description' => $node->get('body')->summary ?? '',
        'card__url' => $node_url,
        'card__image__alt' => $card_alt,
      ];

      $items[] = $item_data;
    }
    $tags = [
      'previous' => 'Anterior',
      'next'     => 'Siguiente',
    ];

    $variables['cards'] = $items;
    $pager = $view->renderPager($tags);
    $variables['pager'] = \Drupal::service('renderer')->renderRoot($pager);
  }
}

function tpms_preprocess_viewfield_item__lista_instituciones__block_1(array &$variables)
{
  if ($view = \Drupal\views\Views::getView('lista_instituciones')) {
    $view->setDisplay('block_1');
    $view->execute();

    $items = [];

    /** @var \Drupal\views\ResultRow $row */
    foreach ($view->result as $index => $row) {
      /** @var \Drupal\group\Entity\Group $group */
      $group = $row->_entity;

      $image_url = NULL;

      // Obtener imagen desde media field
      if ($group->hasField('field_imagen') && !$group->get('field_imagen')->isEmpty()) {
        /** @var \Drupal\media\MediaInterface $media */
        $media = $group->get('field_imagen')->entity;

        if (
          $media instanceof MediaInterface &&
          $media->hasField('field_media_image') &&
          !$media->get('field_media_image')->isEmpty()
        ) {
          /** @var \Drupal\file\FileInterface $file */
          $file = $media->get('field_media_image')->entity;

          if ($file instanceof FileInterface) {
            $uri = $file->getFileUri();
            $style = ImageStyle::load('eventolista');
            if ($style) {
              $image_url = $style->buildUrl($uri);
            }
          }
        }
      }

      $title = $group->label();
      $group_url = $group->toUrl('canonical', ['absolute' => TRUE])->toString();
      $formatted_date = \Drupal::service('date.formatter')->format($group->getCreatedTime(), 'custom', 'd F Y');

      $category_name = '';
      if ($group->hasField('field_categorias_del_event') && !$group->get('field_categorias_del_event')->isEmpty()) {
        $term = Term::load($group->get('field_categorias_del_event')->target_id);
        if ($term) {
          $category_name = $term->getName();
        }
      }

      $category_names = [];

      if ($group->hasField('field_categorias_del_event') && !$group->get('field_categorias_del_event')->isEmpty()) {
        foreach ($group->get('field_categorias_del_event') as $item) {
          $term = Term::load($item->target_id);
          if ($term) {
            $category_names[] = $term->getName();
          }
        }
      }


      $description = '';
      if ($group->hasField('field_body') && !$group->get('field_body')->isEmpty()) {
        $body_item = $group->get('field_body')->first();

        $raw_text = !empty($body_item->summary)
          ? $body_item->summary
          : $body_item->value;

        $plain = strip_tags($raw_text);
        $description = Unicode::truncate($plain, 200, TRUE, TRUE);
      }

      $items[] = [
        'card__image__src' => $image_url,
        'card__title' => $title,
        'card__date' => $formatted_date,
        'card__category' => $category_names,
        'card__description' => $description,
        'card__url' => $group_url,
      ];
    }
    $variables['title'] = $view->getTitle();
    $variables['cards'] = $items;
    $pager = $view->renderPager([
      'previous' => t('Anterior'),
      'next' => t('Siguiente'),
    ]);
    $variables['pager'] = \Drupal::service('renderer')->renderRoot($pager);
  }
}


function tpms_form_views_exposed_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
  if ($form["#id"] === 'views-exposed-form-lista-instituciones-block-1') {
    // Categorias
    /*if ($form['field_categorias_del_event_target_id']) {
      foreach ($form['field_categorias_del_event_target_id']['#options'] as $key => $value) {
        if (!mcj_term_is_assigned($key, 'field_categorias_del_event', 'institucion')) {
          unset($form['field_categorias_del_event_target_id']['#options'][$key]);
        }
      }
    }*/
    // Tipo Instituciones
    if ($form['tipo_de_institucion']) {
      foreach ($form['tipo_de_institucion']['#options'] as $key => $value) {
        if (!tpms_term_is_assigned($key, 'field_tipo_de_institucion', 'institucion')) {
          unset($form['tipo_de_institucion']['#options'][$key]);
        }
      }
    }
  }
}

/**
 * Check if term is assigned to any group
 */
function tpms_term_is_assigned($tid, $term_field, $gtype)
{
  $groups = \Drupal::entityTypeManager()->getStorage('group')->loadByProperties([
    'type' => $gtype,
    $term_field => $tid,
  ]);

  return count($groups) > 0;
}

/**
 * Implements hook_preprocess_viewfield_item__efemerides__block_2().
 */
function tpms_preprocess_viewfield_item__efemerides__block_2(array &$variables)
{
  // ***Elemento destacado (featured)***: obtener primer nodo del display block_2.
  $featured = NULL;
  if ($view = Views::getView('efemerides')) {
    $view->setDisplay('block_2');
    $view->preExecute();
    $view->execute();
    if (!empty($view->result)) {
      /** @var \Drupal\node\NodeInterface $node */
      $node = $view->result[0]->_entity;
      // Título y descripción.
      $title = $node->getTitle();
      $description = tpms_truncate_html($node->body->value, 500, '...');
      // Día: obtener valor y luego etiqueta desde allowed_values.
      $day_val = $node->get('field_dia')->value;
      $day_allowed = $node->get('field_dia')->getFieldDefinition()->getSetting('allowed_values');
      $day_label = isset($day_allowed[$day_val]) ? $day_allowed[$day_val] : '';
      // Mes: análogo.
      $month_val = $node->get('field_mes')->value;
      $month_allowed = $node->get('field_mes')->getFieldDefinition()->getSetting('allowed_values');
      $month_label = isset($month_allowed[$month_val]) ? $month_allowed[$month_val] : '';
      // URL canónica del nodo.
      $url = $node->toUrl()->toString();
      $featured = [
        'title' => $title,
        'description' => $description,
        'date' => $day_label,
        'month' => $month_label,
        'url' => $url,
      ];
    }
  }

  // ***Elementos adicionales (items)***: obtener otros nodos del display attachment_1.
  $items = [];
  if ($view = Views::getView('efemerides')) {
    $view->setDisplay('block_3');
    $view->preExecute();
    $view->execute();
    foreach ($view->result as $row) {
      /** @var \Drupal\node\NodeInterface $node */
      $node = $row->_entity;
      $title = $node->getTitle();
      // Día y mes: obtener etiquetas.
      $day_val = $node->get('field_dia')->value;
      $day_allowed = $node->get('field_dia')->getFieldDefinition()->getSetting('allowed_values');
      $day_label = isset($day_allowed[$day_val]) ? $day_allowed[$day_val] : '';
      $month_val = $node->get('field_mes')->value;
      $month_allowed = $node->get('field_mes')->getFieldDefinition()->getSetting('allowed_values');
      $month_label = isset($month_allowed[$month_val]) ? $month_allowed[$month_val] : '';
      $url = $node->toUrl()->toString();
      $items[] = [
        'title' => $title,
        'date' => $day_label,
        'month' => $month_label,
        'url' => $url,
      ];
    }

    $display = $view->display_handler;

    // 2) Comprueba si el "Ver todas" está activo:
    if ($display->getOption('use_more')) {
      // 3) Toma el texto y la ruta tal cual lo configuraste:
      $text = $display->getOption('use_more_text');
      $path = $display->getOption('link_url');

      // 4) Construye la URL (interna o externa):
      if (preg_match('#^https?://#', $path)) {
        $url = Url::fromUri($path);
      } else {
        $url = Url::fromUserInput($path);
      }

      // 5) Genera el render array del link:
      $link = Link::fromTextAndUrl($text, $url)->toRenderable();
      // (Opcional) añade clases CSS:
      $link['#attributes']['class'] = ['button', 'button--small'];

      // 6) Pásalo a Twig:
      $variables['efemerides_more_link'] = $link;
    }
  }

  // Asignar variables al template Twig.
  $variables['featured'] = $featured;
  $variables['items'] = $items;
  $variables['efemerides_title'] = t('Efemérides destacadas');
}

function tpms_preprocess_viewfield_item__efemerides__block_1(array &$variables)
{

  // ***Elementos adicionales (items)***: obtener otros nodos del display attachment_1.
  $items = [];
  if ($view = Views::getView('efemerides')) {
    $view->setDisplay('block_1');
    $view->preExecute();
    $view->execute();
    foreach ($view->result as $row) {
      /** @var \Drupal\node\NodeInterface $node */
      $node = $row->_entity;
      $title = $node->getTitle();
      $description  = $node->body->value ? $node->body->value : '';
      // Día y mes: obtener etiquetas.
      $day_val = $node->get('field_dia')->value;
      $day_allowed = $node->get('field_dia')->getFieldDefinition()->getSetting('allowed_values');
      $day_label = isset($day_allowed[$day_val]) ? $day_allowed[$day_val] : '';
      $month_val = $node->get('field_mes')->value;
      $month_allowed = $node->get('field_mes')->getFieldDefinition()->getSetting('allowed_values');
      $month_label = isset($month_allowed[$month_val]) ? $month_allowed[$month_val] : '';
      $url = $node->toUrl()->toString();
      $items[] = [
        'title' => $title,
        'description' => $description,
        'date' => $day_label,
        'month' => $month_label,
        'url' => $url,
      ];
    }

    $display = $view->display_handler;

    if ($display->getOption('use_more')) {
      $text = $display->getOption('use_more_text');
      $path = $display->getOption('link_url');

      if (preg_match('#^https?://#', $path)) {
        $url = Url::fromUri($path);
      } else {
        $url = Url::fromUserInput($path);
      }
    }
    $pager = $view->renderPager([
      'previous' => t('Anterior'),
      'next' => t('Siguiente'),
    ]);
    $variables['pager'] = \Drupal::service('renderer')->renderRoot($pager);
  }

  $variables['items'] = $items;
}

function tpms_page_attachments_alter(array &$attachments)
{
  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
