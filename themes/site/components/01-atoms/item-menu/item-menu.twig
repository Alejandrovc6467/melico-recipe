{#
/**
 * Available variables:
 * - link_content - the content of the link (typically text)
 * - link_url - the url this link should poing to
 * - link_attributes - array of attribute,value pairs
 * - link_base_class - the base class name
 * - link_modifiers - array of modifiers to add to the base classname
 * - link_blockname - blockname prepended to the base classname
 *
 * Available blocks:
 * - link_content - used to replace the content of the link
 *     Example: to insert the image component
 */
#}
{% set link_base_class = link_base_class|default('item-menu') %}

{# Asumimos que `is_selected` viene desde PHP/Drupal para marcar el ítem activo #}
{% set link_modifiers = link_modifiers|default([]) %}
{% if is_selected %}
  {% set link_modifiers = link_modifiers|merge(['is-selected']) %}
{% endif %}

<a
  {{ bem(link_base_class, link_modifiers, link_blockname) }}
  {% for attribute, value in link_attributes %}
    {{ attribute }}="{{ value }}"
  {% endfor %}
  href="{{ link_url }}"
>
  {% block link_content %}
    {{ link_content }}
    {% if has_icon %}
    {# ––––– ÍCONOS DESKTOP ––––– #}
      <span class="{{ link_base_class }}__icon icon_default">
      {% include "@atoms/images/icons/_icon.twig" with {
        icon__base_class: link_base_class ~ '__default',
        icon__name: 'down_hover',
        icon__width: '24px',
        icon__height: '24px',
      } %}
      </span>
      <span class="{{ link_base_class }}__icon icon_hover">
      {% include "@atoms/images/icons/_icon.twig" with {
        icon__base_class: link_base_class ~ '__hover',
        icon__name: 'up_hover',
        icon__width: '24px',
        icon__height: '24px',
      } %}
      </span>

      {# ––––– ÍCONOS MOBILE ––––– #}
      <span class="{{ link_base_class }}__icon icon__mobile_default">
        {% include "@atoms/images/icons/_icon.twig" with {
          icon__base_class: link_base_class ~ '__mobile-default',
          icon__name: 'down_hover_m',
          icon__width: '24px',
          icon__height: '24px',
        } %}
      </span>

      <span class="{{ link_base_class }}__icon icon__mobile_hover">
        {% include "@atoms/images/icons/_icon.twig" with {
          icon__base_class: link_base_class ~ '__mobile-hover',
          icon__name: 'up_hover_m',
          icon__width: '24px',
          icon__height: '24px',
        } %}
      </span>
    {% endif %}
  {% endblock %}
</a>
