{% set page_classes = [
  is_front ? 'homepage' : 'not-homepage',
  logged_in ? 'logged-in' : 'logged-out',
  page.sidebar ? 'has-sidebar' : 'no-sidebar'
] %}

<div id="page" class="{{ page_classes|join(' ') }}">
  <div class="header-region">{{ page.header }}</div>
  <div class="breadcrumb-region">{{ page.breadcrumb }}</div>
  <div class="full-region-content{{ page.sidebar ? ' container' : '' }}">
    {% if page.sidebar %}
      <div class="row">
        <div class="sidebar-region col-12 col-lg-3">{{ page.sidebar }}</div>
        <div class="content-region col-12 col-lg-9">{{ page.content }}</div>
      </div>
    {% else %}
      <div class="content-region col-12">{{ page.content }}</div>
    {% endif %}
  </div>
  <div class="footer-region">{{ page.footer }}</div>
</div>
