{#
/**
 * @file
 * Default theme implementation to display a viewfield item.
 *
 * @see template_preprocess_viewfield_item()
 */
#}

{%
  set classes = [
    'field__item instituciones-contenedor',
    'field__item-label-' ~ label_display,
  ]
%}

{%
  set title_classes = [
    'field__item__label',
    label_display == 'visually_hidden' ? 'visually-hidden',
  ]
%}

<div{{ attributes.addClass(classes) }}>
  {% if title %}
    <div class="container instituciones-title">
      <h1 class="view-title">{{ title }}</h1>
    </div>
  {% endif %}
  <div{{ attributes.addClass('page-section lista-instituciones container') }}>
    <div class="layout">
      {# Sidebar desktop con botón de cerrar y título #}
      <div class="sidebar" id="sidebar">
        <div class="border_boton">
          <div class="cerrar">
            <div class="boton_cerrar">
              {% include "@atoms/images/icons/_icon.twig" with {
                icon__name: 'cerrar_filtro',
                icon__height: 40,
                icon__width: 40
              } %}
            </div>
            <div class="title">
              {% include "@atoms/text/headings/_heading.twig" with {
                heading_level: 3,
                heading: "Filters"
              } only %}
            </div>
          </div>
        </div>

        {# Filtros en sidebar desktop #}
        {{ drupal_block('views_exposed_filter_block:lista_instituciones-block_1') }}
      </div>
    </div>

      {# Sidebar móvil con botón toggle y los mismos filtros #}
      <div class="sidebar-filtros">
        {{ drupal_block('views_exposed_filter_block:lista_instituciones-block_1') }}
        <div data-drupal-selector="edit-actions" class="form-actions js-form-wrapper form-wrapper actions-custom" id="edit-actions--4">
          <div class="sidebar-filtros__mobile_button">
            {% include "@atoms/buttons/button.twig" with {
              eventless: true,
              button_id: 'toggleSidebar',
              button_content: 'Filtros',
              button_modifiers: ['tertiary'],
              button_icon: {
                icon_name: 'filtro',
                icon_height: 24,
                icon_width: 24
              }
            } %}
            {% if content['#view'].exposed_raw_input.tipo_de_institucion|length > 0 %}
              <span class="filter-badge">{{ content['#view'].exposed_raw_input.tipo_de_institucion|length }}</span> 
            {% endif %}
          </div>

          <input
            data-drupal-selector="edit-submit-lista-instituciones-3"
            type="submit"
            id="edit-submit-lista-instituciones--3"
            value="Buscar"
            class="button button-primary js-form-submit form-submit form-item__textfield buscar"
          >
        </div>
      </div>

      {# Sección de tarjetas con paginación #}
      {% block cards %}
        {% include "@organisms/lista-instituciones/lista-instituciones.twig" with {
          cards: cards,
          pager: pager
        } %}
      {% endblock %}

  </div>
</div>