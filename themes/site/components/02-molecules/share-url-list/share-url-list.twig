<div class="share-url">
  <h4>Compartir en redes sociales</h4>

  <span class="share-wrapper a2a_kit a2a_kit_size_{{ buttons_size }} addtoany_list" data-a2a-url="{{ link_url }}" data-a2a-title="{{ link_title }}">
    {%- if universal_button_placement == 'before' -%}
      {{- universal_button -}}
    {%- endif -%}

    {%- if addtoany_html -%}
      {{- addtoany_html|raw -}}
    {%- endif -%}

    {%- if universal_button_placement == 'after' -%}
      {{- universal_button -}}
    {%- endif -%}
  </span>
</div>
